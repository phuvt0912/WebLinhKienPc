@model WebLinhKienPc.Models.Contact

@{
    ViewData["Title"] = "Liên hệ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --primary: #a259ff;
        --primary-dark: #8a3fe8;
        --primary-light: #c490ff;
        --success: #4cdf8a;
        --warning: #ffcc44;
        --danger: #ff4f7b;
        --dark-bg: #0a0a1a;
        --card-bg: #12122a;
        --text-primary: #ffffff;
        --text-secondary: #c0c0e0;
        --text-muted: #8a8aba;
        --border: rgba(162, 89, 255, 0.2);
        --font-display: 'Rajdhani', sans-serif;
        --font-body: 'Inter', sans-serif;
    }

    .contact-wrap {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 24px;
    }

    /* Header */
    .contact-header {
        text-align: center;
        margin-bottom: 48px;
    }

    .contact-title {
        font-family: var(--font-display);
        font-size: 42px;
        font-weight: 700;
        background: linear-gradient(135deg, var(--primary-light), var(--primary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 16px;
        letter-spacing: 1px;
    }

    .contact-subtitle {
        font-family: var(--font-body);
        font-size: 16px;
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto;
    }

    /* Grid */
    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
    }

    /* Card chung */
    .contact-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 32px;
        transition: all 0.3s ease;
    }

    .contact-card:hover {
        transform: translateY(-4px);
        border-color: var(--primary);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .card-title {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 700;
        color: var(--primary-light);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .card-title i {
        font-size: 28px;
    }

    /* Info items */
    .info-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
        transition: all 0.2s;
    }

    .info-item:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 48px;
        height: 48px;
        background: rgba(162, 89, 255, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: var(--primary-light);
        flex-shrink: 0;
    }

    .info-content {
        flex: 1;
    }

    .info-label {
        font-family: var(--font-body);
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 4px;
    }

    .info-value {
        font-family: var(--font-body);
        font-size: 16px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .info-value a {
        color: var(--text-primary);
        text-decoration: none;
        transition: color 0.2s;
    }

    .info-value a:hover {
        color: var(--primary-light);
    }

    /* Form */
    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-family: var(--font-body);
        font-size: 14px;
        font-weight: 500;
        color: var(--text-muted);
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        background: var(--dark-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px 16px;
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 14px;
        transition: all 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(162, 89, 255, 0.1);
    }

    .form-control::placeholder {
        color: var(--text-muted);
        opacity: 0.6;
    }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .text-danger {
        color: var(--danger);
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }

    /* Button */
    .btn-submit {
        width: 100%;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 1px;
        padding: 14px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        color: #fff;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(162, 89, 255, 0.3);
    }

    /* Toast */
    .contact-toast {
        position: fixed;
        top: 24px;
        right: 24px;
        z-index: 9999;
        padding: 14px 24px;
        border-radius: 12px;
        font-family: var(--font-body);
        font-size: 14px;
        font-weight: 500;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
        animation: toastIn 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .contact-toast.success {
        background: rgba(18, 18, 42, 0.95);
        border-left: 4px solid var(--success);
        color: var(--success);
    }

    .contact-toast.error {
        background: rgba(18, 18, 42, 0.95);
        border-left: 4px solid var(--danger);
        color: var(--danger);
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateX(30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Map */
    .map-container {
        margin-top: 48px;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

    .map-container iframe {
        width: 100%;
        height: 350px;
        border: none;
        display: block;
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: 24px;
        }
        
        .contact-title {
            font-size: 32px;
        }
    }

    @@media (max-width: 768px) {
        .contact-wrap {
            padding: 0 16px;
            margin: 24px auto;
        }
        
        .contact-card {
            padding: 24px;
        }
        
        .card-title {
            font-size: 20px;
        }
        
        .info-icon {
            width: 40px;
            height: 40px;
            font-size: 20px;
        }
        
        .info-value {
            font-size: 14px;
        }
        
        .map-container iframe {
            height: 250px;
        }
    }
</style>

<div class="contact-wrap">
    <!-- Header -->
    <div class="contact-header">
        <h1 class="contact-title">📞 Liên hệ với chúng tôi</h1>
        <p class="contact-subtitle">
            Hỗ trợ nhanh chóng – Tư vấn tận tâm – Phản hồi sớm nhất
        </p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="contact-toast success" id="toast">
            ✅ @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="contact-toast error" id="toast">
            ❌ @TempData["Error"]
        </div>
    }

    <div class="contact-grid">
        <!-- Left - Thông tin liên hệ -->
        <div class="contact-card">
            <div class="card-title">
                <i class="bi bi-info-circle-fill"></i>
                <span>Thông tin liên hệ</span>
            </div>

            <div class="info-item">
                <div class="info-icon">
                    <i class="bi bi-geo-alt-fill"></i>
                </div>
                <div class="info-content">
                    <div class="info-label">Địa chỉ</div>
                    <div class="info-value">123 Đường ABC, Phường XYZ, Quận 1, TP. Hồ Chí Minh</div>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">
                    <i class="bi bi-telephone-fill"></i>
                </div>
                <div class="info-content">
                    <div class="info-label">Hotline</div>
                    <div class="info-value">
                        <a href="tel:0123456789">0123 456 789</a>
                    </div>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">
                    <i class="bi bi-envelope-fill"></i>
                </div>
                <div class="info-content">
                    <div class="info-label">Email</div>
                    <div class="info-value">
                        <a href="mailto:support@linhkienpc.com">support@linhkienpc.com</a>
                    </div>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">
                    <i class="bi bi-clock-fill"></i>
                </div>
                <div class="info-content">
                    <div class="info-label">Giờ làm việc</div>
                    <div class="info-value">Thứ 2 - Thứ 7: 8:00 - 21:00<br>Chủ Nhật: 9:00 - 18:00</div>
                </div>
            </div>
        </div>

        <!-- Right - Form liên hệ -->
        <div class="contact-card">
            <div class="card-title">
                <i class="bi bi-chat-dots-fill"></i>
                <span>Gửi tin nhắn</span>
            </div>

            <form asp-action="Contact" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>👤 Họ và tên</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập họ tên của bạn" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>📧 Email</label>
                    <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>📞 Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" placeholder="0123 456 789" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>📝 Nội dung</label>
                    <textarea asp-for="Message" class="form-control" rows="5" placeholder="Nhập nội dung cần hỗ trợ..."></textarea>
                    <span asp-validation-for="Message" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit">
                    <i class="bi bi-send-fill"></i>
                    Gửi liên hệ
                </button>
            </form>
        </div>
    </div>

    <!-- Google Maps -->
    <div class="map-container">
        <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.3588228145195!2d106.696301!3d10.776889!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f3f0f5f5f5f%3A0x5f5f5f5f5f5f5f5f!2zSOG7kyBDaMOtIE1pbmggVmluaA!5e0!3m2!1svi!2s!4v1700000000000!5m2!1svi!2s" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
        </iframe>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Auto hide toast after 3 seconds
        const toast = document.getElementById('toast');
        if (toast) {
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.4s';
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        }
    </script>
}