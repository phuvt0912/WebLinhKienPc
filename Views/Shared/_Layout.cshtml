<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebLinhKienPc</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebLinhKienPc.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

    @inject Microsoft.AspNetCore.Identity.SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> _SignInManager
    @if (_SignInManager.IsSignedIn(User) && !User.IsInRole("Admin") && !User.IsInRole("NhanVien"))
    {
        <link rel="stylesheet" href="~/css/chat-widget.css" asp-append-version="true" />
    }
</head>
<body>
    <partial name="_Header" />

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @await Component.InvokeAsync("Footer")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* Chat Widget — chỉ hiện với khách hàng *@
    @if (_SignInManager.IsSignedIn(User) && !User.IsInRole("Admin") && !User.IsInRole("NhanVien"))
    {
        <div id="chatWidget">
            <button class="chat-fab" id="chatFab" onclick="toggleChat()">
                <span id="fabIcon">💬</span>
                <span class="fab-badge" id="fabBadge" style="display:none">0</span>
            </button>

            <div class="chat-box" id="chatBox" style="display:none">
                <div class="chat-hdr">
                    <div class="chat-hdr-left">
                        <div class="chat-hdr-avatar">L</div>
                        <div>
                            <div class="chat-hdr-title">Hỗ trợ LinhKienPC</div>
                            <div class="chat-hdr-sub">
                                <span class="online-dot"></span>AI + Nhân viên sẵn sàng
                            </div>
                        </div>
                    </div>
                    <button class="chat-hdr-close" onclick="toggleChat()">✕</button>
                </div>

                <div class="chat-msgs" id="chatMsgs"></div>

                <div class="chat-footer">
                    <input type="text"
                           class="chat-input"
                           id="chatInput"
                           placeholder="Nhập tin nhắn..."
                           onkeydown="if(event.key==='Enter')sendChat()" />
                    <button class="chat-send-btn" id="chatSendBtn" onclick="sendChat()">➤</button>
                </div>
            </div>
        </div>

        <script src="~/js/chat-widget.js" asp-append-version="true"></script>
    }
</body>
</html>