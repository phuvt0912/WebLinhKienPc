@model WebLinhKienPc.Models.SiteInfo

<link rel="stylesheet" href="~/css/footer.css" />

<footer class="footer">

    <!-- TOP: SHOWROOM -->
    <div class="footer-top">
        <div class="container">

            <h5 class="footer-title">Hệ thống cửa hàng</h5>

            <div class="row">

                @if (Model?.Addresses != null && Model.Addresses.Any())
                {
                    foreach (var addr in Model.Addresses)
                    {
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="showroom-card">

                                <div class="showroom-header">
                                    <span class="icon">📍</span>
                                    <span class="branch">@addr.Branch</span>
                                </div>

                                <div class="showroom-body">
                                    <p>@addr.Street, @addr.District</p>
                                    <p>@addr.City</p>

                                    <div class="contact">
                                        <span>📞 @Model.Phone</span>
                                        <span>📧 @Model.Email</span>
                                    </div>

                                    @{
                                        var wh = Model.WorkHours?.FirstOrDefault();
                                    }

                                    @if (wh != null)
                                    {
                                        <div class="time">
                                            🕒 @wh.OpenHour.ToString(@"hh\:mm") -
                                            @wh.CloseHour.ToString(@"hh\:mm")
                                        </div>
                                    }
                                </div>

                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-center">Chưa có dữ liệu chi nhánh</p>
                }

            </div>

        </div>
    </div>

    <!-- BOTTOM -->
    <div class="footer-bottom">
        <div class="container">

            <div class="row gy-4">

                <!-- BRAND -->
                <div class="col-lg-3 col-md-6">
                    <div class="footer-brand">@Model?.Name</div>
                    <p class="footer-desc">@Model?.Slogan</p>
                </div>

                <!-- CONTACT -->
                <div class="col-lg-3 col-md-6">
                    <h6>Liên hệ</h6>
                    <ul class="footer-list">
                        <li>📞 @Model?.Phone</li>
                        <li>📧 @Model?.Email</li>
                        <li>🌐 @Model?.SiteURL</li>
                    </ul>
                </div>

                <!-- SUPPORT -->
                <div class="col-lg-3 col-md-6">
                    <h6>Hỗ trợ</h6>
                    <ul class="footer-list">
                        <li><a href="#">Hướng dẫn mua hàng</a></li>
                        <li><a href="#">Thanh toán</a></li>
                        <li><a href="#">Bảo hành</a></li>
                    </ul>
                </div>

                <!-- POLICY -->
                <div class="col-lg-3 col-md-6">
                    <h6>Chính sách</h6>
                    <ul class="footer-list">
                        <li><a href="#">Bảo mật</a></li>
                        <li><a href="#">Đổi trả</a></li>
                        <li><a href="#">Điều khoản</a></li>
                    </ul>
                </div>

            </div>

        </div>
    </div>

</footer>