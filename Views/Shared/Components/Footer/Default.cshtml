@model WebLinhKienPc.Models.SiteInfo

<footer class="border-top footer text-muted mt-5">

    <style>
            /* ===== TOP FOOTER ===== */
            .footer-top {
                background: linear-gradient(135deg, #1a1f3c, #2a2f5a);
                color: #e0e7ff;
                padding: 40px 0;
                border-radius: 16px 16px 0 0;
                border: 1px solid #2e3a8c;
            }

                .footer-top h5 {
                    text-align: center;
                    font-weight: 700;
                    margin-bottom: 30px;
                }

            /* SHOWROOM CARD */
            .showroom-card {
                background: #0f172a;
                border-radius: 16px;
                padding: 20px;
                transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
                height: 100%;
                border: 1px solid #1e293b;
                color: #c7d2fe;
                display: flex;
                flex-direction: column;
            }

                .showroom-card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 10px 25px rgba(79,70,229,0.4);
                    border-color: #4f46e5;
                }

            .showroom-title {
                font-weight: 600;
                margin-bottom: 10px;
                font-size: 16px;
                color: #e0e7ff;
            }

            .showroom-card p {
                margin: 4px 0;
                font-size: 14px;
            }

                .showroom-card p:last-child {
                    margin-bottom: 0;
                }

            /* ===== BOTTOM FOOTER ===== */
            .footer-bottom {
                background: #020617;
                padding: 35px 0;
                border-top: 1px solid #1e293b;
            }

                .footer-bottom h6 {
                    font-weight: 600;
                    margin-bottom: 15px;
                    color: #e0e7ff;
                }

                .footer-bottom p,
                .footer-bottom a {
                    font-size: 14px;
                    color: #94a3b8;
                    margin-bottom: 6px;
                    display: block;
                    text-decoration: none;
                    transition: 0.2s;
                }

                    .footer-bottom a:hover {
                        color: #4f46e5;
                        transform: translateX(3px);
                    }

            /* BRAND */
            .footer-brand {
                font-size: 20px;
                font-weight: bold;
                margin-bottom: 10px;
                color: #4f46e5;
            }
    </style>

    <!-- TOP FOOTER -->
    <div class="footer-top">
        <div class="container">
            <h5>Hệ thống cửa hàng</h5>

            <div class="row g-4 align-items-stretch justify-content-center">
                @if (Model?.Addresses != null && Model.Addresses.Any())
                {
                    foreach (var addr in Model.Addresses)
                    {
                        <div class="col-md-6 col-lg-4 d-flex">
                            <div class="showroom-card flex-fill">

                                <div class="showroom-title">
                                    📍 @(addr.Branch ?? "")
                                </div>

                                <p>
                                    @(
                                        string.Join(" ", new[]
                                        {
                                            (!string.IsNullOrWhiteSpace(addr.StreetNumber) && !string.IsNullOrWhiteSpace(addr.Street))
                                                ? $"{addr.StreetNumber} {addr.Street}" : null,
                                            !string.IsNullOrWhiteSpace(addr.Ward) ? $"Phường {addr.Ward}" : null,
                                            !string.IsNullOrWhiteSpace(addr.District) ? $"Quận {addr.District}" : null,
                                            !string.IsNullOrWhiteSpace(addr.City) ? $"Thành phố {addr.City}" : null
                                        }.Where(x => !string.IsNullOrWhiteSpace(x)))
                                    )
                                </p>

                                <p>📞 @Model?.Phone</p>
                                <p>📧 @Model?.Email</p>

                                @if (Model.WorkHours != null && Model.WorkHours.Any())
                                {
                                    var wh = Model.WorkHours.First();
                                    <p>
                                        🕒 @wh.OpenHour.ToString(@"hh\:mm") - @wh.CloseHour.ToString(@"hh\:mm")
                                        (@ToVN(wh.StartDay) - @ToVN(wh.EndDay))
                                    </p>
                                }

                            </div>
                        </div>
                    }
                }
                else
                {
                    <p style="text-align:center; width:100%;">Chưa có dữ liệu chi nhánh</p>
                }
            </div>
        </div>
    </div>

    <!-- BOTTOM FOOTER -->
    <div class="footer-bottom">
        <div class="container">
            <div class="row">

                <!-- BRAND -->
                <div class="col-md-3">
                    <div class="footer-brand">@Model?.Name</div>
                    <p>@Model?.Slogan</p>
                </div>

                <!-- CONTACT -->
                <div class="col-md-3">
                    <h6>Liên hệ</h6>
                    <p>📞 @Model?.Phone</p>
                    <p>📧 @Model?.Email</p>
                    <p>🌐 @Model?.SiteURL</p>
                </div>

                <!-- SUPPORT -->
                <div class="col-md-3">
                    <h6>Hỗ trợ</h6>
                    <a href="#">Hướng dẫn mua hàng</a>
                    <a href="#">Thanh toán</a>
                    <a href="#">Bảo hành</a>
                </div>

                <!-- POLICY -->
                <div class="col-md-3">
                    <h6>Chính sách</h6>
                    <a href="#">Bảo mật</a>
                    <a href="#">Đổi trả</a>
                    <a href="#">Điều khoản</a>
                </div>

            </div>
        </div>
    </div>
</footer>

@functions {
    public string ToVN(DayOfWeek d)
    {
        return d switch
        {
            DayOfWeek.Monday => "T2",
            DayOfWeek.Tuesday => "T3",
            DayOfWeek.Wednesday => "T4",
            DayOfWeek.Thursday => "T5",
            DayOfWeek.Friday => "T6",
            DayOfWeek.Saturday => "T7",
            DayOfWeek.Sunday => "CN",
            _ => ""
        };
    }
}