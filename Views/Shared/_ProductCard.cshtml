@{
    var stockClass = Model.Stock > 10 ? "stock-ok" : Model.Stock > 0 ? "stock-low" : "stock-out";
    var stockLabel = Model.Stock > 10 ? "Còn hàng" : Model.Stock > 0 ? $"Còn {Model.Stock} sản phẩm" : "Hết hàng";

    var safeName = Model.Name.Replace("\\", "\\\\").Replace("'", "\\'");
    var safeDesc = (Model.Description ?? "").Replace("\\", "\\\\").Replace("'", "\\'").Replace("\n", "\\n").Replace("\r", "");
    var safeImg = Model.ImageUrl ?? "";
    var safeCat = (Model.Category?.Name ?? "").Replace("'", "\\'");
}

<div class="product-card">

    <div class="product-img-wrap">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="product-img" />
        }
        else
        {
            <div class="product-img-empty">📷</div>
        }
    </div>

    <div class="product-body">
        <div class="product-name">@Model.Name</div>
        <div class="product-price">@Model.Price.ToString("N0") ₫</div>
        <div class="product-stock @stockClass">@stockLabel</div>
    </div>

    <button class="btn-quickview"
            onclick="openQuickView(@Model.ProductId, '@Model.Name', '@Model.ImageUrl', @Model.Price, '', @Model.Stock, '@Model.Description')">
        👁 Xem nhanh
    </button>

    <a class="btn-detail"
           asp-controller="Product"
           asp-action="Details"
           asp-route-id="@Model.ProductId">
        Xem chi tiết →
    </a>

</div>