@model WebLinhKienPc.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container mt-4">

    <div class="row">

        <!-- Ảnh sản phẩm -->
        <div class="col-md-5">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid border rounded" />
            }
            else
            {
                <img src="/images/no-image.png" class="img-fluid border rounded" />
            }
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-7">

            <h2>@Model.Name</h2>

            <p class="text-muted">
                Danh mục: @Model.Category?.Name
            </p>

            <h3 class="text-danger">
                @Model.Price.ToString("N0") VNĐ
            </h3>

            <p>
                Tồn kho: <strong>@Model.Stock</strong>
            </p>

            <hr />

            <h5>Mô tả sản phẩm</h5>

            <p>
                @Model.Description
            </p>

            <hr />

            <div class="mt-3">

                <button class="btn btn-success btn-lg">
                    Mua ngay
                </button>

                <button class="btn btn-primary btn-lg">
                    Thêm vào giỏ
                </button>

            </div>

        </div>

    </div>

</div>