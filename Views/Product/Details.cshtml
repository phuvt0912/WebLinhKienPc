@model WebLinhKienPc.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .detail-wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 48px;
    }

    /* Breadcrumb */
    .breadcrumb-wrap {
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        color: #6a6a9a;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .breadcrumb-wrap a {
        color: #6a6a9a;
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb-wrap a:hover { color: #a259ff; }
    .breadcrumb-wrap .sep { color: #3a3a5a; }
    .breadcrumb-wrap .current { color: #c0c0e0; }

    /* Layout */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: start;
    }

    /* Image */
    .product-img-wrap {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        background: #12122a;
        border: 1px solid rgba(162, 89, 255, 0.15);
        aspect-ratio: 1;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-img-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
        color: #2a2a4a;
        min-height: 400px;
    }

    .category-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        padding: 4px 12px;
        background: rgba(13, 13, 26, 0.85);
        border: 1px solid rgba(162, 89, 255, 0.3);
        border-radius: 4px;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        color: #a259ff;
        backdrop-filter: blur(4px);
    }

    /* Info */
    .product-info { display: flex; flex-direction: column; gap: 20px; }

    .product-name {
        font-family: 'Rajdhani', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: #e8e8ff;
        line-height: 1.3;
        margin: 0;
    }

    .product-price {
        font-family: 'Rajdhani', sans-serif;
        font-size: 36px;
        font-weight: 700;
        background: linear-gradient(135deg, #a259ff, #00cfff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
    }

    .stock-info {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
    }

    .stock-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .stock-ok .stock-dot { background: #4cdf8a; }
    .stock-low .stock-dot { background: #ffaa00; }
    .stock-out .stock-dot { background: #ff4f7b; }
    .stock-ok { color: #4cdf8a; }
    .stock-low { color: #ffaa00; }
    .stock-out { color: #ff4f7b; }

    .divider {
        height: 1px;
        background: rgba(162, 89, 255, 0.1);
    }

    /* Quantity */
    .qty-label {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #6a6a9a;
        margin-bottom: 10px;
        display: block;
    }

    .qty-wrap {
        display: flex;
        align-items: center;
        gap: 0;
        width: fit-content;
        background: #12122a;
        border: 1px solid rgba(162, 89, 255, 0.2);
        border-radius: 8px;
        overflow: hidden;
    }

    .qty-btn {
        width: 40px;
        height: 44px;
        background: none;
        border: none;
        color: #a259ff;
        font-size: 20px;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .qty-btn:hover { background: rgba(162, 89, 255, 0.1); }
    .qty-btn:disabled { color: #3a3a5a; cursor: not-allowed; }

    .qty-input {
        width: 60px;
        height: 44px;
        background: transparent;
        border: none;
        border-left: 1px solid rgba(162, 89, 255, 0.15);
        border-right: 1px solid rgba(162, 89, 255, 0.15);
        color: #e8e8ff;
        font-family: 'Rajdhani', sans-serif;
        font-size: 18px;
        font-weight: 700;
        text-align: center;
        outline: none;
        -moz-appearance: textfield;
    }

    .qty-input::-webkit-outer-spin-button,
    .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

    /* Total price */
    .total-wrap {
        background: rgba(162, 89, 255, 0.06);
        border: 1px solid rgba(162, 89, 255, 0.15);
        border-radius: 10px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .total-label {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        color: #6a6a9a;
    }

    .total-price {
        font-family: 'Rajdhani', sans-serif;
        font-size: 28px;
        font-weight: 700;
        background: linear-gradient(135deg, #a259ff, #00cfff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Buttons */
    .action-btns {
        display: flex;
        gap: 12px;
    }

    .btn-buy {
        flex: 1;
        padding: 14px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #6c2bd9, #a259ff);
        color: #fff;
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-buy:hover { opacity: 0.85; }

    .btn-cart {
        flex: 1;
        padding: 14px;
        border: 1.5px solid rgba(0, 207, 255, 0.4);
        border-radius: 10px;
        background: rgba(0, 207, 255, 0.06);
        color: #00cfff;
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-cart:hover {
        background: rgba(0, 207, 255, 0.12);
        border-color: #00cfff;
    }

    .btn-buy:disabled,
    .btn-cart:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    /* Description */
    .desc-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #a259ff;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .desc-text {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        color: #8888aa;
        line-height: 1.7;
    }
</style>

<div class="detail-wrap">

    <!-- Breadcrumb -->
    <div class="breadcrumb-wrap">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span class="sep">›</span>
        <a asp-controller="Product" asp-action="Index">Sản phẩm</a>
        <span class="sep">›</span>
        <span class="current">@Model.Name</span>
    </div>

    <div class="detail-grid">

        <!-- Ảnh -->
        <div class="product-img-wrap">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img class="product-img" src="@Model.ImageUrl" alt="@Model.Name" />
            }
            else
            {
                <div class="product-img-empty">📷</div>
            }
            @if (Model.Category != null)
            {
                <span class="category-badge">@Model.Category.Name</span>
            }
        </div>

        <!-- Thông tin -->
        <div class="product-info">

            <h1 class="product-name">@Model.Name</h1>

            <div class="product-price">@Model.Price.ToString("N0") ₫</div>

            @{
                var stockClass = Model.Stock > 10 ? "stock-ok" : Model.Stock > 0 ? "stock-low" : "stock-out";
                var stockLabel = Model.Stock > 10 ? "Còn hàng" : Model.Stock > 0 ? $"Còn {Model.Stock} sản phẩm" : "Hết hàng";
            }
            <div class="stock-info @stockClass">
                <span class="stock-dot"></span>
                @stockLabel
            </div>

            <div class="divider"></div>

            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                <input type="hidden" name="productId" value="@Model.ProductId" />

                <!-- Số lượng -->
                <span class="qty-label">Số lượng</span>
                <div class="qty-wrap">
                    <button type="button" class="qty-btn" onclick="decrease()" id="btnDecrease">−</button>
                    <input type="number"
                           id="quantity"
                           name="quantity"
                           value="1"
                           min="1"
                           max="@Model.Stock"
                           class="qty-input"
                           oninput="updateTotal()" />
                    <button type="button" class="qty-btn" onclick="increase()" id="btnIncrease">+</button>
                </div>

                <!-- Tổng tiền -->
                <div class="total-wrap" style="margin-top:16px">
                    <span class="total-label">Thành tiền</span>
                    <span class="total-price" id="totalprice">@Model.Price.ToString("N0") ₫</span>
                </div>

                <div class="divider" style="margin-top:20px"></div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div>
                        <div class="desc-title">Mô tả sản phẩm</div>
                        <div class="desc-text">@Model.Description</div>
                    </div>
                    <div class="divider"></div>
                }

                <!-- Buttons -->
                <div class="action-btns">
                    <button type="submit"
                            name="action"
                            value="buy"
                            class="btn-buy"
                            @(Model.Stock == 0 ? "disabled" : "")>
                        🛒 Mua ngay
                    </button>
                    <button type="submit"
                            name="action"
                            value="cart"
                            class="btn-cart"
                            @(Model.Stock == 0 ? "disabled" : "")>
                        + Giỏ hàng
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    const price = @Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const maxStock = @Model.Stock;

    function updateTotal() {
        let qty = parseInt(document.getElementById('quantity').value) || 1;
        if (qty < 1) qty = 1;
        if (qty > maxStock) qty = maxStock;
        document.getElementById('quantity').value = qty;
        document.getElementById('totalprice').innerText =
            (qty * price).toLocaleString('vi-VN') + ' ₫';

        document.getElementById('btnDecrease').disabled = qty <= 1;
        document.getElementById('btnIncrease').disabled = qty >= maxStock;
    }

    function increase() {
        let qty = document.getElementById('quantity');
        if (parseInt(qty.value) < maxStock) {
            qty.value = parseInt(qty.value) + 1;
            updateTotal();
        }
    }

    function decrease() {
        let qty = document.getElementById('quantity');
        if (parseInt(qty.value) > 1) {
            qty.value = parseInt(qty.value) - 1;
            updateTotal();
        }
    }

    // Init
    updateTotal();
</script>