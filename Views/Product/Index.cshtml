@model IEnumerable<WebLinhKienPc.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">

    <h2 class="text-center mb-4">Sản phẩm mới</h2>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top" style="height:200px;object-fit:cover;" />
                    }
                    else
                    {
                        <img src="/images/no-image.png" class="card-img-top" style="height:200px;object-fit:cover;" />
                    }

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@item.Name</h5>

                        <p class="text-muted">
                            Danh mục: @item.Category?.Name
                        </p>

                        <p class="text-danger fw-bold fs-5">
                            @item.Price.ToString("N0") VNĐ
                        </p>

                        <p>
                            Còn lại: @item.Stock
                        </p>

                        <a asp-controller="Product"
                           asp-action="Detail"
                           asp-route-id="@item.ProductId"
                           class="btn btn-primary mt-auto">
                            Xem chi tiết
                        </a>

                    </div>

                </div>
            </div>
        }

    </div>

</div>