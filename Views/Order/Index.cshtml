@model IEnumerable<WebLinhKienPc.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .ord-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 32px;
    }

    .ord-page-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 30px;
        font-weight: 700;
        color: #e8e8ff;
        margin: 0 0 8px;
    }

    .ord-page-sub {
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        color: #6a6a9a;
        margin-bottom: 28px;
    }

    .ord-page-sub span { color: #a259ff; font-weight: 500; }

    .ord-filter {
        display: flex;
        gap: 10px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .ord-filter-btn {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 500;
        padding: 8px 20px;
        border-radius: 20px;
        border: 1px solid rgba(162,89,255,0.2);
        background: transparent;
        color: #6a6a9a;
        cursor: pointer;
        transition: all 0.2s;
    }

    .ord-filter-btn:hover,
    .ord-filter-btn.active {
        background: rgba(162,89,255,0.1);
        border-color: #a259ff;
        color: #a259ff;
    }

    .ord-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Inter', sans-serif;
        font-size: 15px;
    }

    .ord-table th {
        padding: 15px 20px;
        background: rgba(162,89,255,0.1);
        color: #a259ff;
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 15px;
        letter-spacing: 0.8px;
        border-bottom: 2px solid rgba(162,89,255,0.2);
        text-align: center;
        white-space: nowrap;
    }

    .ord-table th:first-child { text-align: left; }

    .ord-table td {
        padding: 18px 20px;
        color: #c0c0e0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        vertical-align: middle;
        text-align: center;
    }

    .ord-table td:first-child { text-align: left; }
    .ord-table tr:hover td { background: rgba(162,89,255,0.03); }

    .ord-code {
        font-family: 'Rajdhani', sans-serif;
        font-size: 17px;
        font-weight: 700;
        color: #a259ff;
    }

    .ord-date-main { color: #c0c0e0; font-size: 15px; }
    .ord-date-time { font-size: 13px; color: #6a6a9a; margin-top: 3px; }

    .ord-price {
        font-family: 'Rajdhani', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: #4cdf8a;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-pending   { background:rgba(255,170,0,0.12);  color:#ffaa00; border:1px solid rgba(255,170,0,0.25); }
    .status-shipping  { background:rgba(0,207,255,0.1);   color:#00cfff; border:1px solid rgba(0,207,255,0.25); }
    .status-completed { background:rgba(76,223,138,0.1);  color:#4cdf8a; border:1px solid rgba(76,223,138,0.25); }
    .status-cancelled { background:rgba(255,79,123,0.1);  color:#ff4f7b; border:1px solid rgba(255,79,123,0.25); }

    .btn-detail {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 14px;
        padding: 8px 20px;
        border-radius: 8px;
        border: 1px solid rgba(162,89,255,0.3);
        background: rgba(162,89,255,0.06);
        color: #a259ff;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }

    .btn-detail:hover {
        background: rgba(162,89,255,0.15);
        border-color: #a259ff;
        color: #c490ff;
    }

    .empty-state {
        text-align: center;
        padding: 80px 0;
        color: #6a6a9a;
        font-family: 'Inter', sans-serif;
        font-size: 16px;
    }

    .empty-icon { font-size: 52px; display: block; margin-bottom: 16px; }

    .btn-shop {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 20px;
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 0.8px;
        padding: 12px 28px;
        border-radius: 8px;
        border: none;
        background: linear-gradient(135deg, #6c2bd9, #a259ff);
        color: #fff;
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .btn-shop:hover { opacity: 0.85; color: #fff; }
</style>

<div class="ord-wrap">

    <h2 class="ord-page-title">Đơn hàng của tôi</h2>
    <p class="ord-page-sub">Bạn có <span>@Model.Count()</span> đơn hàng</p>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <span class="empty-icon">📭</span>
            Bạn chưa có đơn hàng nào
            <br>
            <a asp-controller="Product" asp-action="Index" class="btn-shop">🛍️ Mua sắm ngay</a>
        </div>
    }
    else
    {
        <div class="ord-filter">
            <button class="ord-filter-btn active" onclick="filterStatus('', this)">Tất cả</button>
            <button class="ord-filter-btn" onclick="filterStatus('status-pending', this)">⏳ Chờ xử lý</button>
            <button class="ord-filter-btn" onclick="filterStatus('status-shipping', this)">🚚 Đang giao</button>
            <button class="ord-filter-btn" onclick="filterStatus('status-completed', this)">✅ Hoàn thành</button>
            <button class="ord-filter-btn" onclick="filterStatus('status-cancelled', this)">❌ Đã huỷ</button>
        </div>

        <table class="ord-table">
            <thead>
                <tr>
                    <th>Mã đơn hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Phương thức thanh toán</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody id="ordBody">
                @foreach (var item in Model.OrderByDescending(o => o.OrderDate))
                {
                    string statusClass = item.Status switch {
                        OrderStatus.Pending   => "status-pending",
                        OrderStatus.Shipping  => "status-shipping",
                        OrderStatus.Completed => "status-completed",
                        OrderStatus.Cancelled => "status-cancelled",
                        _ => "status-pending"
                    };
                    string statusLabel = item.Status switch {
                        OrderStatus.Pending   => "⏳ Chờ xử lý",
                        OrderStatus.Shipping  => "🚚 Đang giao",
                        OrderStatus.Completed => "✅ Hoàn thành",
                        OrderStatus.Cancelled => "❌ Đã huỷ",
                        _ => item.Status.ToString()
                    };
                    <tr data-status="@statusClass">
                        <td><div class="ord-code">#@item.OrderCode</div></td>
                        <td>
                            <div class="ord-date-main">@item.OrderDate.ToString("dd/MM/yyyy")</div>
                            <div class="ord-date-time">@item.OrderDate.ToString("HH:mm")</div>
                        </td>
                        <td><span class="ord-price">@item.TotalPrice.ToString("N0") ₫</span></td>
                        <td><span class="status-badge @statusClass">@statusLabel</span></td>
                        <td class="ord-payment">
                            @(item.PaymentMethod == PaymentMethod.CashOnDelivery ? "Thanh toán khi nhận hàng" : "QR Code / Chuyển khoản")
                        </td>
                        <td>
                            <a class="btn-detail"
                               asp-controller="Order"
                               asp-action="OrderDetails"
                               asp-route-id="@item.OrderId">
                                Chi tiết →
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script>
    function filterStatus(status, btn) {
        document.querySelectorAll('.ord-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('#ordBody tr[data-status]').forEach(row => {
            row.style.display = (!status || row.dataset.status === status) ? '' : 'none';
        });
    }
</script>