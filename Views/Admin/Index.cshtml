@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/Admin/Index.css">

<div class="dash-wrap">

    <h2 class="page-title">Dashboard</h2>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card revenue">
            <span class="stat-icon">📈</span>
            <div class="stat-label">Tổng doanh thu</div>
            <div class="stat-value revenue">
                @(ViewBag.TotalRevenue != null
                    ? ((decimal)ViewBag.TotalRevenue).ToString("N0") + " ₫"
                    : "0 ₫")
            </div>
        </div>

        <div class="stat-card products">
            <span class="stat-icon">📦</span>
            <div class="stat-label">Sản phẩm</div>
            <div class="stat-value products">@(ViewBag.ProductCount ?? 0)</div>
        </div>

        <div class="stat-card orders">
            <span class="stat-icon">🛒</span>
            <div class="stat-label">Đơn hàng</div>
            <div class="stat-value orders">@(ViewBag.OrderCount ?? 0)</div>
        </div>

        <div class="stat-card users">
            <span class="stat-icon">👥</span>
            <div class="stat-label">Người dùng</div>
            <div class="stat-value users">@(ViewBag.UserCount ?? 0)</div>
        </div>
    </div>

    <div class="divider"></div>

    <!-- Đơn hàng -->
    <div class="section-header">
        <h4 class="section-title">Đơn hàng gần đây</h4>
    </div>

    <!-- Filter -->
    <form method="get" asp-action="Index">
        <div class="filter-bar">
            <select name="status" class="filter-select">
                <option value="">Tất cả trạng thái</option>
                <option value="Pending">Chờ xử lý</option>
                <option value="Shipping">Đang giao</option>
                <option value="Completed">Hoàn thành</option>
                <option value="Cancelled">Đã huỷ</option>
            </select>
            <button type="submit" class="btn-filter">🔍 Lọc</button>
        </div>
    </form>

    <!-- Table -->
    <table class="order-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Khách hàng</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Ngày đặt</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !((IEnumerable<dynamic>)Model).Any())
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">
                            <span class="empty-icon">🛒</span>
                            Chưa có đơn hàng nào
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var order in Model)
                {
                    string statusClass = order.Status switch
                    {
                        "Pending" => "status-pending",
                        "Shipping" => "status-shipping",
                        "Completed" => "status-completed",
                        "Cancelled" => "status-cancelled",
                        _ => "status-pending"
                    };

                    string statusLabel = order.Status switch
                    {
                        "Pending" => "Chờ xử lý",
                        "Shipping" => "Đang giao",
                        "Completed" => "Hoàn thành",
                        "Cancelled" => "Đã huỷ",
                        _ => order.Status
                    };

                    <tr>
                        <td class="order-id">#@order.Id</td>
                        <td class="order-customer">@order.CustomerName</td>
                        <td class="order-total">
                            @((order.Total as decimal?)?.ToString("N0") ?? "0") ₫
                        </td>
                        <td>
                            <span class="status-badge @statusClass">@statusLabel</span>
                        </td>
                        <td style="color:#8888aa;font-size:13px">
                            @order.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td>
                            <a class="btn-detail"
                               asp-action="OrderDetail"
                               asp-route-id="@order.Id">
                                Chi tiết
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

</div>