@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">

    <h2 class="mb-4">Dashboard</h2>

    <!-- Thống kê -->
    <div class="row">

        <div class="col-md-3">
            <div class="card text-white bg-primary shadow">
                <div class="card-body">
                    <h5>Tổng doanh thu</h5>
                    <h3>@ViewBag.TotalRevenue VNĐ</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-success shadow">
                <div class="card-body">
                    <h5>Số sản phẩm</h5>
                    <h3>@ViewBag.ProductCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-warning shadow">
                <div class="card-body">
                    <h5>Đơn hàng</h5>
                    <h3>@ViewBag.OrderCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-danger shadow">
                <div class="card-body">
                    <h5>Người dùng</h5>
                    <h3>@ViewBag.UserCount</h3>
                </div>
            </div>
        </div>

    </div>

    <hr />

    <!-- Bộ lọc đơn hàng -->
    <h4 class="mt-4">Đơn hàng</h4>

    <form method="get" asp-action="Index">
        <div class="row mb-3">

            <div class="col-md-3">
                <select name="status" class="form-control">
                    <option value="">Tất cả</option>
                    <option value="Pending">Chờ xử lý</option>
                    <option value="Shipping">Đang giao</option>
                    <option value="Completed">Hoàn thành</option>
                </select>
            </div>

            <div class="col-md-3">
                <button class="btn btn-primary">Lọc</button>
            </div>

        </div>
    </form>

    <!-- Bảng đơn hàng -->
    <table class="table table-bordered table-striped">

        <thead>
            <tr>
                <th>ID</th>
                <th>Khách</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Ngày</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.CustomerName</td>
                    <td>@order.Total</td>
                    <td>@order.Status</td>
                    <td>@order.CreatedDate</td>

                    <td>
                        <a asp-action="OrderDetail" asp-route-id="@order.Id" class="btn btn-sm btn-info">
                            Chi tiết
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>