@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var topProducts   = ViewBag.TopProducts   as IEnumerable<dynamic> ?? new List<dynamic>();
    var lowStockProds = ViewBag.LowStockProducts as IEnumerable<dynamic> ?? new List<dynamic>();
    var revenueData   = ViewBag.RevenueByMonth as IEnumerable<dynamic> ?? new List<dynamic>();
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .dash-wrap {
    padding: 32px 40px;
    max-width: 100%;
    box-sizing: border-box;
}

.page-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 32px; font-weight: 700;
    color: #e8e8ff; margin: 0 0 28px;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    margin-bottom: 32px;
}

.stat-card {
    background: #12122a;
    border: 1px solid rgba(162,89,255,0.15);
    border-radius: 14px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s, transform 0.2s;
}

.stat-card:hover {
    border-color: rgba(162,89,255,0.3);
    transform: translateY(-3px);
}

.stat-icon { font-size: 30px; }

.stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #6a6a9a;
    text-transform: uppercase;
    letter-spacing: 0.6px;
}

.stat-value {
    font-family: 'Rajdhani', sans-serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
}

.stat-value.revenue  { color: #4cdf8a; }
.stat-value.products { color: #00cfff; }
.stat-value.orders   { color: #a259ff; }
.stat-value.users    { color: #ffaa00; }
.stat-value.pending  { color: #ff4f7b; }
.stat-value.lowstock { color: #ff8c00; }

.stat-sub {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #6a6a9a;
    margin-top: 2px;
}

.stat-sub.warn { color: #ff4f7b; }

.dash-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.dash-full { margin-bottom: 20px; }

.dash-card {
    background: #12122a;
    border: 1px solid rgba(162,89,255,0.15);
    border-radius: 14px;
    overflow: hidden;
}

.dash-card-hdr {
    padding: 18px 24px;
    border-bottom: 1px solid rgba(162,89,255,0.1);
    background: rgba(162,89,255,0.04);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.dash-card-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 18px; font-weight: 700;
    color: #a259ff; letter-spacing: 0.5px;
}

.dash-card-body { padding: 20px 24px; }

.chart-wrap {
    padding: 24px;
    position: relative;
    height: 300px;
}

.top-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
}

.top-table th {
    padding: 13px 18px;
    color: #6a6a9a;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    border-bottom: 1px solid rgba(162,89,255,0.1);
    background: rgba(162,89,255,0.05);
    font-weight: 600;
}

.top-table td {
    padding: 14px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: middle;
    color: #c0c0e0;
}

.top-table tr:last-child td { border-bottom: none; }
.top-table tr:hover td { background: rgba(162,89,255,0.03); }

.rank-badge {
    display: inline-flex;
    align-items: center; justify-content: center;
    width: 32px; height: 32px;
    border-radius: 8px;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700; font-size: 16px;
}

.rank-1 { background: rgba(255,215,0,0.15);  color: #FFD700; border: 1px solid rgba(255,215,0,0.3); }
.rank-2 { background: rgba(192,192,192,0.12); color: #C0C0C0; border: 1px solid rgba(192,192,192,0.25); }
.rank-3 { background: rgba(205,127,50,0.12);  color: #CD7F32; border: 1px solid rgba(205,127,50,0.25); }
.rank-n { background: rgba(162,89,255,0.08);  color: #6a6a9a; border: 1px solid rgba(162,89,255,0.15); }

.prod-thumb {
    width: 44px; height: 44px;
    border-radius: 8px;
    object-fit: cover;
    border: 1px solid rgba(162,89,255,0.15);
    background: #0d0d1a;
    flex-shrink: 0;
}

.prod-thumb-empty {
    width: 44px; height: 44px;
    border-radius: 8px;
    background: #1a1a35;
    border: 1px solid rgba(162,89,255,0.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; color: #3a3a5a; flex-shrink: 0;
}

.prod-name {
    font-weight: 500; color: #e8e8ff;
    font-size: 15px;
    max-width: 220px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.sold-bar-wrap { display: flex; align-items: center; gap: 10px; }

.sold-bar-bg {
    flex: 1; height: 8px;
    background: rgba(255,255,255,0.06);
    border-radius: 4px; overflow: hidden;
}

.sold-bar {
    height: 100%;
    background: linear-gradient(90deg, #a259ff, #00cfff);
    border-radius: 4px;
    transition: width 0.8s ease;
}

.sold-num {
    font-family: 'Rajdhani', sans-serif;
    font-size: 17px; font-weight: 700;
    color: #a259ff; min-width: 32px; text-align: right;
}

.revenue-num {
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px; font-weight: 600;
    color: #4cdf8a; white-space: nowrap;
}

.low-list { display: flex; flex-direction: column; gap: 12px; }

.low-item {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 14px;
    background: rgba(255,140,0,0.05);
    border: 1px solid rgba(255,140,0,0.12);
    border-radius: 10px;
}

.low-name {
    flex: 1; font-size: 15px; font-weight: 500;
    color: #e8e8ff;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.low-stock-badge {
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px; font-weight: 700;
    padding: 4px 12px; border-radius: 6px;
    white-space: nowrap; flex-shrink: 0;
}
.stock-0 {
    background: rgba(255,79,123,0.15);
    color: #ff4f7b;
    border: 1px solid rgba(255,79,123,0.35);
}

.out-of-stock {
    background: rgba(255,79,123,0.04);
    border-color: rgba(255,79,123,0.15);
}

.stock-1 { background: rgba(255,79,123,0.12); color: #ff4f7b; border: 1px solid rgba(255,79,123,0.25); }
.stock-3 { background: rgba(255,140,0,0.12);  color: #ff8c00; border: 1px solid rgba(255,140,0,0.25); }
.stock-5 { background: rgba(255,170,0,0.1);   color: #ffaa00; border: 1px solid rgba(255,170,0,0.2); }

.low-more {
    font-family: 'Inter', sans-serif;
    font-size: 13px; color: #6a6a9a;
    text-align: center; padding-top: 10px;
}

.low-more a { color: #a259ff; text-decoration: none; }
.low-more a:hover { text-decoration: underline; }

@@media (max-width: 1200px) {
    .stats-grid { grid-template-columns: repeat(3, 1fr); }
    .dash-row { grid-template-columns: 1fr; }
}
</style>

<div class="dash-wrap">

    <h2 class="page-title">Dashboard</h2>

    <!-- ===== STATS ===== -->
    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-icon">📈</span>
            <div class="stat-label">Doanh thu</div>
            <div class="stat-value revenue">
                @(ViewBag.TotalRevenue != null
                    ? ((decimal)ViewBag.TotalRevenue).ToString("N0") + " ₫"
                    : "0 ₫")
            </div>
            <div class="stat-sub">Đơn hoàn thành</div>
        </div>

        <div class="stat-card">
            <span class="stat-icon">📦</span>
            <div class="stat-label">Sản phẩm</div>
            <div class="stat-value products">@(ViewBag.ProductCount ?? 0)</div>
            <div class="stat-sub">Tổng sản phẩm</div>
        </div>

        <div class="stat-card">
            <span class="stat-icon">🛒</span>
            <div class="stat-label">Đơn hàng</div>
            <div class="stat-value orders">@(ViewBag.OrderCount ?? 0)</div>
            <div class="stat-sub">Tổng đơn hàng</div>
        </div>

        <div class="stat-card">
            <span class="stat-icon">👥</span>
            <div class="stat-label">Người dùng</div>
            <div class="stat-value users">@(ViewBag.UserCount ?? 0)</div>
            <div class="stat-sub">Tài khoản</div>
        </div>

        <div class="stat-card">
            <span class="stat-icon">⏳</span>
            <div class="stat-label">Chờ xử lý</div>
            <div class="stat-value pending">@(ViewBag.PendingCount ?? 0)</div>
            <div class="stat-sub @((int)(ViewBag.PendingCount ?? 0) > 0 ? "warn" : "")">
                @((int)(ViewBag.PendingCount ?? 0) > 0 ? "Cần xử lý!" : "Không có")
            </div>
        </div>

        <div class="stat-card">
            <span class="stat-icon">⚠️</span>
            <div class="stat-label">Sắp hết hàng</div>
            <div class="stat-value lowstock">@(ViewBag.LowStockCount ?? 0)</div>
            <div class="stat-sub @((int)(ViewBag.LowStockCount ?? 0) > 0 ? "warn" : "")">
                @((int)(ViewBag.LowStockCount ?? 0) > 0 ? "Cần nhập thêm" : "Ổn định")
            </div>
        </div>
    </div>

    <!-- ===== BIỂU ĐỒ DOANH THU (full width) ===== -->
    <div class="dash-full dash-card">
        <div class="dash-card-hdr">
            <span class="dash-card-title">📊 Doanh thu 12 tháng gần nhất</span>
        </div>
        <div class="chart-wrap">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- ===== 2 CỘT: TOP SP + SẮP HẾT ===== -->
    <div class="dash-row">

        <!-- Top sản phẩm bán chạy -->
        <div class="dash-card">
            <div class="dash-card-hdr">
                <span class="dash-card-title">🏆 Top sản phẩm bán chạy</span>
                <span style="font-size:12px;color:#6a6a9a;font-family:'Inter',sans-serif">Top 10</span>
            </div>
            <div style="overflow-x:auto">
                <table class="top-table">
                    <thead>
                        <tr>
                            <th style="width:40px">#</th>
                            <th>Sản phẩm</th>
                            <th>Đã bán</th>
                            <th>Doanh thu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var topList = topProducts.ToList();
                            int maxSold = topList.Any() ? (int)topList[0].TotalSold : 1;
                        }
                        @for (int i = 0; i < topList.Count; i++)
                        {
                            var p        = topList[i];
                            int rank     = i + 1;
                            string rankClass = rank == 1 ? "rank-1" : rank == 2 ? "rank-2" : rank == 3 ? "rank-3" : "rank-n";
                            int barPct   = maxSold > 0 ? (int)((p.TotalSold / (double)maxSold) * 100) : 0;

                            <tr>
                                <td><span class="rank-badge @rankClass">@rank</span></td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px">
                                        @if (!string.IsNullOrEmpty((string)p.ImageUrl))
                                        {
                                            <img src="@p.ImageUrl" class="prod-thumb" alt="" />
                                        }
                                        else
                                        {
                                            <div class="prod-thumb-empty">📷</div>
                                        }
                                        <span class="prod-name">@p.Name</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="sold-bar-wrap">
                                        <div class="sold-bar-bg">
                                            <div class="sold-bar" style="width:@barPct%"></div>
                                        </div>
                                        <span class="sold-num">@p.TotalSold</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="revenue-num">@(((decimal)p.TotalRevenue).ToString("N0")) ₫</span>
                                </td>
                            </tr>
                        }
                        @if (!topList.Any())
                        {
                            <tr>
                                <td colspan="4" style="text-align:center;padding:32px;color:#6a6a9a;font-family:'Inter',sans-serif;font-size:13px">
                                    Chưa có dữ liệu bán hàng
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Sắp hết hàng -->
        <div class="dash-card">
            <div class="dash-card-hdr">
                <span class="dash-card-title">⚠️ Sản phẩm sắp hết hàng</span>
                <span style="font-size:12px;color:#6a6a9a;font-family:'Inter',sans-serif">Stock ≤ 5 + Hết hàng</span>
            </div>
            <div class="dash-card-body">
                @if (lowStockProds.Any())
                {
                    <div class="low-list">
                        @foreach (var p in lowStockProds)
                        {
                            int stock = (int)p.Stock;
                            string sc = stock == 0 ? "stock-0" : stock <= 1 ? "stock-1" : stock <= 3 ? "stock-3" : "stock-5";
                            string stockLabel = stock == 0 ? "Hết hàng" : $"Còn {stock}";

                            <div class="low-item @(stock == 0 ? "out-of-stock" : "")">
                                @if (!string.IsNullOrEmpty((string)p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" class="prod-thumb" alt="" />
                                }
                                else
                                {
                                    <div class="prod-thumb-empty">📷</div>
                                }
                                <span class="low-name">@p.Name</span>
                                <span class="low-stock-badge @sc">@stockLabel</span>
                            </div>
                        }
                    </div>

                    @if ((int)(ViewBag.LowStockCount ?? 0) > 5)
                    {
                        <div class="low-more">
                            Và <strong>@((int)ViewBag.LowStockCount - 5)</strong> sản phẩm khác —
                            <a asp-controller="AdminProduct" asp-action="Index">Xem tất cả</a>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:40px 0;color:#6a6a9a;font-family:'Inter',sans-serif;font-size:13px">
                        <div style="font-size:32px;margin-bottom:10px">✅</div>
                        Tất cả sản phẩm còn hàng tốt
                    </div>
                }
            </div>
        </div>

    </div>
</div>

<!-- Chart.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
    const labels   = [@Html.Raw(string.Join(",", revenueData.Select(r => $"\"{r.label}\"")))];
    const revenues = [@Html.Raw(string.Join(",", revenueData.Select(r => r.revenue)))];

    const ctx = document.getElementById('revenueChart').getContext('2d');

    const gradient = ctx.createLinearGradient(0, 0, 0, 240);
    gradient.addColorStop(0, 'rgba(162,89,255,0.35)');
    gradient.addColorStop(1, 'rgba(162,89,255,0)');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels,
            datasets: [{
                label: 'Doanh thu (₫)',
                data: revenues,
                borderColor: '#a259ff',
                backgroundColor: gradient,
                borderWidth: 2.5,
                pointBackgroundColor: '#a259ff',
                pointBorderColor: '#12122a',
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 7,
                tension: 0.4,
                fill: true,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#1a1a35',
                    borderColor: 'rgba(162,89,255,0.3)',
                    borderWidth: 1,
                    titleColor: '#a259ff',
                    bodyColor: '#e8e8ff',
                    padding: 12,
                    callbacks: {
                        label: ctx => ' ' + Number(ctx.raw).toLocaleString('vi-VN') + ' ₫'
                    }
                }
            },
            scales: {
                x: {
                    grid: { color: 'rgba(255,255,255,0.04)' },
                    ticks: { color: '#6a6a9a', font: { family: 'Inter', size: 12 } }
                },
                y: {
                    grid: { color: 'rgba(255,255,255,0.04)' },
                    ticks: {
                        color: '#6a6a9a',
                        font: { family: 'Inter', size: 12 },
                        callback: val => {
                            if (val >= 1_000_000) return (val/1_000_000).toFixed(0) + 'M';
                            if (val >= 1_000)     return (val/1_000).toFixed(0) + 'K';
                            return val;
                        }
                    }
                }
            }
        }
    });
</script>