@using Microsoft.AspNetCore.Identity
@model IdentityUser
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminAccount/edit-account.css">

<div class="form-wrap">
    <h2 class="page-title">Sửa Tài Khoản</h2>
    <p class="page-sub">Chỉnh sửa thông tin tài khoản</p>

    <div class="edit-info">
        Đang sửa: <span>@Model.Email</span>
    </div>

    <form asp-action="EditAccount" asp-route-id="@Model.Id" method="post" id="editForm">
        @Html.AntiForgeryToken()

        <!-- Email -->
        <div class="field">
            <label>Email <span style="color:#ff4f7b">*</span></label>
            <input type="email"
                   name="email"
                   value="@Model.Email"
                   placeholder="user@example.com"
                   autocomplete="off" />
        </div>

        <div class="divider"></div>

        <!-- Username -->
        <div class="field">
            <label>Username <span style="color:#ff4f7b">*</span></label>
            <input type="text"
                   name="username"
                   value="@Model.UserName"
                   placeholder="Nhập username hiển thị..."
                   autocomplete="off" />
            <span class="field-note">Username sẽ hiển thị trên giao diện thay vì email.</span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="submitBtn">
                ✏️ Lưu thay đổi
            </button>
            <a asp-action="Index" class="btn-back">← Quay lại</a>
        </div>
    </form>
</div>

<script>
    document.getElementById('editForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.textContent = 'Đang lưu...';
        btn.disabled = true;
    });
</script>