@using Microsoft.AspNetCore.Identity
@model IdentityUser
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .form-wrap { padding: 36px 40px; max-width: 560px; }

    .page-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: #a259ff;
        margin: 0 0 6px;
        line-height: 1.2;
    }

    .page-sub {
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        color: #6a6a9a;
        margin-bottom: 28px;
    }

    .edit-info {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: rgba(0, 207, 255, 0.06);
        border: 1px solid rgba(0, 207, 255, 0.15);
        border-radius: 6px;
        margin-bottom: 28px;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        color: #6a6a9a;
    }

    .edit-info span { color: #00cfff; font-weight: 500; }

    .field { margin-bottom: 24px; }

    .field label {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 12px;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #6a6a9a;
        display: block;
        margin-bottom: 8px;
    }

    .field input {
        width: 100%;
        background: #12122a;
        border: 1px solid rgba(162, 89, 255, 0.2);
        border-radius: 8px;
        padding: 12px 16px;
        color: #e8e8ff;
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .field input:focus {
        border-color: #a259ff;
        box-shadow: 0 0 0 3px rgba(162, 89, 255, 0.1);
    }

    .field input::placeholder { color: #3a3a5a; }

    .field input:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .divider {
        height: 1px;
        background: rgba(162, 89, 255, 0.1);
        margin: 8px 0 24px;
    }

    .field-note {
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        color: #6a6a9a;
        margin-top: 6px;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px;
    }

    .btn-submit {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 15px;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 11px 28px;
        border-radius: 8px;
        border: none;
        background: linear-gradient(135deg, #0f7a8a, #00cfff);
        color: #fff;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-submit:hover { opacity: 0.85; }
    .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-back {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 15px;
        padding: 11px 28px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        color: #6a6a9a;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
    }

    .btn-back:hover {
        border-color: rgba(162,89,255,0.3);
        color: #c0c0e0;
    }
</style>

<div class="form-wrap">
    <h2 class="page-title">Sửa Tài Khoản</h2>
    <p class="page-sub">Chỉnh sửa thông tin tài khoản</p>

    <div class="edit-info">
        Đang sửa: <span>@Model.Email</span>
    </div>

    <form asp-action="EditAccount" asp-route-id="@Model.Id" method="post" id="editForm">
        @Html.AntiForgeryToken()

        <!-- Email -->
        <div class="field">
            <label>Email <span style="color:#ff4f7b">*</span></label>
            <input type="email"
                   name="email"
                   value="@Model.Email"
                   placeholder="user@example.com"
                   autocomplete="off" />
            <span class="field-note">Đổi email sẽ đồng thời đổi username.</span>
        </div>

        <div class="divider"></div>

        <!-- ID (readonly) -->
        <div class="field">
            <label>ID tài khoản</label>
            <input type="text" value="@Model.Id" disabled />
            <span class="field-note">Không thể thay đổi.</span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="submitBtn">
                ✏️ Lưu thay đổi
            </button>
            <a asp-action="Index" class="btn-back">← Quay lại</a>
        </div>
    </form>
</div>

<script>
    document.getElementById('editForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.textContent = 'Đang lưu...';
        btn.disabled = true;
    });
</script>