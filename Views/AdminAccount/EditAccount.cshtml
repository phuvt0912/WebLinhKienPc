@using Microsoft.AspNetCore.Identity
@model IdentityUser
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .form-wrap { padding: 36px 40px; max-width: 560px; }

    .page-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: #a259ff;
        margin: 0 0 6px;
        line-height: 1.2;
    }

    .page-sub {
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        color: #6a6a9a;
        margin-bottom: 28px;
    }

    .edit-info {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: rgba(0, 207, 255, 0.06);
        border: 1px solid rgba(0, 207, 255, 0.15);
        border-radius: 6px;
        margin-bottom: 28px;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        color: #6a6a9a;
    }

    .edit-info span { color: #00cfff; font-weight: 500; }

    .field { margin-bottom: 24px; }

    .field label {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 12px;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #6a6a9a;
        display: block;
        margin-bottom: 8px;
    }

    .field input {
        width: 100%;
        background: #12122a;
        border: 1px solid rgba(162, 89, 255, 0.2);
        border-radius: 8px;
        padding: 12px 16px;
        color: #e8e8ff;
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
    }

    .field input:focus {
        border-color: #a259ff;
        box-shadow: 0 0 0 3px rgba(162, 89, 255, 0.1);
    }

    .field input::placeholder { color: #3a3a5a; }

    .field input:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .field-note {
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        color: #6a6a9a;
        margin-top: 6px;
    }

    .divider {
        height: 1px;
        background: rgba(162, 89, 255, 0.1);
        margin: 8px 0 24px;
    }

    /* Section password */
    .section-hdr {
        font-family: 'Rajdhani', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #e8e8ff;
        letter-spacing: 0.5px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .section-hdr::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(162,89,255,0.15);
    }

    .pwd-wrap {
        position: relative;
    }

    .pwd-wrap input {
        padding-right: 46px;
    }

    .pwd-eye {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #6a6a9a;
        cursor: pointer;
        font-size: 16px;
        padding: 0;
        line-height: 1;
        transition: color 0.2s;
    }

    .pwd-eye:hover { color: #a259ff; }

    .pwd-note {
        margin-top: 10px;
        padding: 10px 14px;
        background: rgba(162,89,255,0.05);
        border: 1px solid rgba(162,89,255,0.1);
        border-radius: 6px;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        color: #6a6a9a;
    }

    .pwd-strength {
        display: flex;
        gap: 4px;
        margin-top: 8px;
    }

    .pwd-bar {
        height: 3px;
        flex: 1;
        border-radius: 2px;
        background: rgba(255,255,255,0.08);
        transition: background 0.3s;
    }

    .pwd-strength-label {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        color: #6a6a9a;
        margin-top: 5px;
        text-align: right;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px;
    }

    .btn-submit {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 15px;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 11px 28px;
        border-radius: 8px;
        border: none;
        background: linear-gradient(135deg, #0f7a8a, #00cfff);
        color: #fff;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-submit:hover { opacity: 0.85; }
    .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-back {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 15px;
        padding: 11px 28px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        color: #6a6a9a;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
    }

    .btn-back:hover {
        border-color: rgba(162,89,255,0.3);
        color: #c0c0e0;
    }

    .alert-success {
        padding: 12px 16px;
        background: rgba(76,223,138,0.08);
        border: 1px solid rgba(76,223,138,0.25);
        border-radius: 8px;
        color: #4cdf8a;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        margin-bottom: 20px;
    }

    .alert-error {
        padding: 12px 16px;
        background: rgba(255,79,123,0.08);
        border: 1px solid rgba(255,79,123,0.25);
        border-radius: 8px;
        color: #ff4f7b;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        margin-bottom: 20px;
    }
</style>

<div class="form-wrap">
    <h2 class="page-title">Sửa Tài Khoản</h2>
    <p class="page-sub">Chỉnh sửa thông tin tài khoản</p>

    <div class="edit-info">
        Đang sửa: <span>@Model.Email</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-error">❌ @TempData["Error"]</div>
    }

    <form asp-action="EditAccount" asp-route-id="@Model.Id" method="post" id="editForm">
        @Html.AntiForgeryToken()

        <!-- ===== THÔNG TIN CƠ BẢN ===== -->
        <div class="section-hdr">Thông tin tài khoản</div>

        <div class="field">
            <label>Email <span style="color:#ff4f7b">*</span></label>
            <input type="email"
                   name="email"
                   value="@Model.Email"
                   placeholder="user@example.com"
                   autocomplete="off" />
        </div>

        <div class="field">
            <label>Username <span style="color:#ff4f7b">*</span></label>
            <input type="text"
                   name="username"
                   value="@Model.UserName"
                   placeholder="Nhập username hiển thị..."
                   autocomplete="off" />
            <span class="field-note">Username sẽ hiển thị trên giao diện thay vì email.</span>
        </div>

        <div class="divider"></div>

        <!-- ===== ĐỔI MẬT KHẨU ===== -->
        <div class="section-hdr">Đổi mật khẩu</div>

        <div class="field">
            <label>Mật khẩu mới</label>
            <div class="pwd-wrap">
                <input type="password"
                       name="newPassword"
                       id="newPassword"
                       placeholder="Để trống nếu không đổi"
                       autocomplete="new-password"
                       oninput="checkStrength(this.value)" />
                <button type="button" class="pwd-eye" onclick="togglePwd('newPassword', this)">👁</button>
            </div>
            <div class="pwd-strength" id="pwdStrength">
                <div class="pwd-bar" id="bar1"></div>
                <div class="pwd-bar" id="bar2"></div>
                <div class="pwd-bar" id="bar3"></div>
                <div class="pwd-bar" id="bar4"></div>
            </div>
            <div class="pwd-strength-label" id="pwdStrengthLabel"></div>
        </div>

        <div class="field">
            <label>Xác nhận mật khẩu mới</label>
            <div class="pwd-wrap">
                <input type="password"
                       name="confirmPassword"
                       id="confirmPassword"
                       placeholder="Nhập lại mật khẩu mới"
                       autocomplete="new-password"
                       oninput="checkMatch()" />
                <button type="button" class="pwd-eye" onclick="togglePwd('confirmPassword', this)">👁</button>
            </div>
            <div class="pwd-note">
                ℹ️ Để trống cả 2 ô nếu không muốn đổi mật khẩu. Mật khẩu phải có ít nhất 6 ký tự, 1 chữ hoa, 1 ký tự đặc biệt.
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="submitBtn">
                ✏️ Lưu thay đổi
            </button>
            <a asp-action="Index" class="btn-back">← Quay lại</a>
        </div>
    </form>
</div>

<script>
    // Toggle hiện/ẩn mật khẩu
    function togglePwd(id, btn) {
        const input = document.getElementById(id);
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        btn.textContent = isHidden ? '🙈' : '👁';
    }

    // Kiểm tra độ mạnh mật khẩu
    function checkStrength(val) {
        const bars   = [1,2,3,4].map(i => document.getElementById('bar' + i));
        const label  = document.getElementById('pwdStrengthLabel');
        const colors = ['#ff4f7b', '#ffaa00', '#00cfff', '#4cdf8a'];
        const labels = ['Yếu', 'Trung bình', 'Khá', 'Mạnh'];

        let score = 0;
        if (val.length >= 6)  score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;

        bars.forEach((b, i) => {
            b.style.background = i < score ? colors[score - 1] : 'rgba(255,255,255,0.08)';
        });

        label.textContent   = val.length > 0 ? labels[score - 1] || '' : '';
        label.style.color   = val.length > 0 ? colors[score - 1] : '#6a6a9a';

        checkMatch();
    }

    // Kiểm tra khớp mật khẩu
    function checkMatch() {
        const newPwd     = document.getElementById('newPassword').value;
        const confirmPwd = document.getElementById('confirmPassword');

        if (confirmPwd.value.length === 0) {
            confirmPwd.style.borderColor = 'rgba(162,89,255,0.2)';
            return;
        }

        if (newPwd === confirmPwd.value) {
            confirmPwd.style.borderColor = '#4cdf8a';
            confirmPwd.style.boxShadow   = '0 0 0 3px rgba(76,223,138,0.1)';
        } else {
            confirmPwd.style.borderColor = '#ff4f7b';
            confirmPwd.style.boxShadow   = '0 0 0 3px rgba(255,79,123,0.1)';
        }
    }

    // Submit form
    document.getElementById('editForm').addEventListener('submit', function (e) {
        const newPwd     = document.getElementById('newPassword').value;
        const confirmPwd = document.getElementById('confirmPassword').value;

        // Nếu nhập mật khẩu mới → phải khớp
        if (newPwd && newPwd !== confirmPwd) {
            e.preventDefault();
            alert('Mật khẩu xác nhận không khớp!');
            return;
        }

        const btn = document.getElementById('submitBtn');
        btn.textContent = 'Đang lưu...';
        btn.disabled    = true;
    });
</script>