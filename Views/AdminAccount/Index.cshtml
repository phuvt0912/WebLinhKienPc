@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityUser>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Tài Khoản";
    var roles = ViewBag.UserRoles as Dictionary<string, string>;
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminAccount/Index.css">

<div class="page-wrap">

    <div class="page-header">
        <h2 class="page-title">Quản Lý Tài Khoản</h2>
        <div class="header-actions">
            <a class="btn-add" asp-action="CreateAccount">+ Tạo tài khoản</a>
            <a class="btn-roles" asp-action="Roles">🔐 Xem Chức Danh</a>
        </div>
    </div>

    <div class="total-count">
        Tổng cộng <span>@Model.Count()</span> tài khoản
    </div>

    <table class="user-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Username</th>
                <th>Role hiện tại</th>
                <th>Đổi Role</th>
                <th style="text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">
                            <span class="empty-icon">👤</span>
                            Chưa có tài khoản nào
                        </div>
                    </td>
                </tr>
            }
            else
            {
                var allRoles = ViewBag.AllRoles as List<string> ?? new List<string> { "Admin", "NhanVien", "KhachHang" };
                @foreach (var user in Model)
                {
                    var role = roles != null && roles.ContainsKey(user.Id)
                        ? roles[user.Id] : "KhachHang";

                    <tr>
                        <td>
                            <span class="user-id" title="@user.Id">
                                @user.Id[..8]...
                            </span>
                        </td>
                        <td class="user-email">@user.Email</td>
                        <td class="user-name">@user.UserName</td>
                        <td>
                            @{
                                var roleLabel = role switch
                                {
                                    "Admin" => "⚡ Admin",
                                    "NhanVien" => "🔧 Nhân viên",
                                    "KhachHang" => "👤 Khách hàng",
                                    _ => "👤 " + role
                                };
                                var roleClass = role switch
                                {
                                    "Admin" => "role-Admin",
                                    "NhanVien" => "role-NhanVien",
                                    "KhachHang" => "role-KhachHang",
                                    _ => "role-Custom"
                                };
                            }
                            <span class="role-badge @roleClass">@roleLabel</span>
                        </td>
                        <td>
                            <form asp-action="ChangeRole" method="post"
                                  style="display:inline-flex;gap:6px;align-items:center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="newRole" class="role-select">
                                    @foreach (var r in allRoles)
                                    {
                                        <option value="@r" selected="@(r == role)">@r</option>
                                    }
                                </select>
                                <button type="submit" class="btn-save-role">Lưu</button>
                            </form>
                        </td>
                        <td style="text-align: center;">
                            <div class="action-wrap" style="justify-content: center;">
                                <a class="btn-edit"
                                   asp-action="EditAccount"
                                   asp-route-id="@user.Id">
                                    ✏️ Sửa
                                </a>
                                <form id="del-@user.Id" asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="button" class="btn-delete"
                                            onclick="confirmDelete('@user.Id', '@user.Email')">
                                        🗑️ Xoá
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-icon">🗑️</div>
        <div class="modal-title">Xác nhận xoá</div>
        <div class="modal-msg">
            Bạn có chắc muốn xoá tài khoản<br>
            <span class="modal-name" id="modalName"></span>?
        </div>
        <div class="modal-note">Hành động này không thể hoàn tác.</div>
        <div class="modal-actions">
            <button class="modal-btn-cancel" onclick="closeModal()">Huỷ</button>
            <button class="modal-btn-confirm" onclick="submitDelete()">Xoá</button>
        </div>
    </div>
</div>

<script>
    let currentUserId = null;

    function confirmDelete(id, email) {
        currentUserId = id;
        document.getElementById('modalName').textContent = email;
        document.getElementById('modalOverlay').classList.add('show');
    }

    function closeModal() {
        document.getElementById('modalOverlay').classList.remove('show');
        currentUserId = null;
    }

    function submitDelete() {
        if (currentUserId) {
            document.getElementById('del-' + currentUserId).submit();
        }
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeModal();
    });
</script>