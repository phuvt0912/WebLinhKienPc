@model WebLinhKienPc.ViewModels.CreateUserViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Tài Khoản";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminAccount/create-account.css">


<div class="form-wrap">

    <div class="page-header">
        <h2 class="page-title">Tạo Tài Khoản</h2>
        <p class="page-sub">Tạo tài khoản mới và gán quyền</p>
    </div>

    <form asp-action="CreateAccount" method="post" id="createForm">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="validation-summary text-danger"></div>

        <!-- Email -->
        <div class="field">
            <div class="field-header">
                <label>Email <span style="color:#ff4f7b">*</span></label>
            </div>
            <input asp-for="Email" placeholder="user@example.com" autocomplete="off" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <!-- Mật khẩu -->
        <div class="field">
            <div class="field-header">
                <label>Mật khẩu <span style="color:#ff4f7b">*</span></label>
            </div>
            <input asp-for="Password" type="password" placeholder="Tối thiểu 6 ký tự..." />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <!-- Nhập lại mật khẩu -->
        <div class="field">
            <div class="field-header">
                <label>Nhập lại mật khẩu <span style="color:#ff4f7b">*</span></label>
            </div>
            <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu..." />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="divider"></div>

        <!-- Role -->
        <div class="field">
            <div class="field-header">
                <label>Phân quyền <span style="color:#ff4f7b">*</span></label>
            </div>
            <select asp-for="Role" id="roleSelect" onchange="updateRolePreview(this.value)">
                @foreach (var r in ViewBag.Roles)
                {
                    <option value="@r">@r</option>
                }
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>

            <!-- Preview badge role -->
            <div class="role-preview KhachHang" id="rolePreview">
                👤 Khách hàng
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit" id="submitBtn">
                + Tạo tài khoản
            </button>
            <a asp-action="Index" asp-controller="AdminAccount" class="btn-back">
                ← Quay lại
            </a>
        </div>

    </form>
</div>

<script>
    const roleLabels = {
        'Admin': '⚡ Admin',
        'NhanVien': '🔧 Nhân viên',
        'KhachHang': '👤 Khách hàng'
    };
    // (Cập nhật giao diện hiển thị role đang được chọn (nếu có trong roleLabels) thì hiển thị icon + tên, nếu không thì hiển thị mặc định)
    function updateRolePreview(role) {
        const preview = document.getElementById('rolePreview');
        preview.className = 'role-preview ' + role;
        preview.textContent = roleLabels[role] || '👤 ' + role;
    }

    // Init preview theo role đầu tiên
    const firstRole = document.getElementById('roleSelect')?.value;
    if (firstRole) updateRolePreview(firstRole);

    document.getElementById('createForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.textContent = 'Đang tạo...';
        btn.disabled = true;
    });
</script>