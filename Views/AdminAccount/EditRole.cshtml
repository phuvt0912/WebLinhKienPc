@model Microsoft.AspNetCore.Identity.IdentityRole
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminAccount/edit-role.css">

<div class="form-wrap">
    <h2 class="page-title">Sửa Role</h2>
    <p class="page-sub">Đổi tên role hiện có</p>

    <div class="edit-info">
        Đang sửa: <span>@Model.Name</span>
    </div>

    <form asp-action="EditRole" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="field">
            <label>Tên role mới <span style="color:#ff4f7b">*</span></label>
            <input type="text" name="roleName" value="@Model.Name" autocomplete="off" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">✏️ Lưu thay đổi</button>
            <a asp-action="Roles" class="btn-back">← Quay lại</a>
        </div>
    </form>
</div>