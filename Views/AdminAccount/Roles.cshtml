@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminAccount/roles.css">

<div class="page-wrap">

    <div class="page-header">
        <h2 class="page-title">Quản Lý Chức Danh</h2>
        <div class="header-actions">
            <a class="btn-back" asp-action="Index">← Quay lại</a>
            <a class="btn-add" asp-action="CreateRole">+ Tạo Chức Danh</a>
        </div>
    </div>

    <div class="total-count">
        Tổng cộng <span>@Model.Count()</span> role
    </div>

    <table class="role-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên Role</th>
                <th style="text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="3">
                        <div class="empty-state">
                            <span class="empty-icon">🔐</span>
                            Chưa có role nào
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var role in Model)
                {
                    var badgeClass = role.Name switch
                    {
                        "Admin" => "Admin",
                        "NhanVien" => "NhanVien",
                        "KhachHang" => "KhachHang",
                        _ => "other"
                    };

                    var roleIcon = role.Name switch
                    {
                        "Admin" => "⚡",
                        "NhanVien" => "🔧",
                        "KhachHang" => "👤",
                        _ => "🔧"
                    };

                    <tr>
                        <td>
                            <span class="role-id" title="@role.Id">
                                @role.Id[..8]...
                            </span>
                        </td>
                        <td>
                            <span class="role-badge @badgeClass">
                                @roleIcon @role.Name
                            </span>
                        </td>
                        <td style="text-align: center;">
                            <div style="display:inline-flex;gap:8px;align-items:center;justify-content:center">
                                <a class="btn-edit"
                                   asp-action="EditRole"
                                   asp-route-id="@role.Id">
                                    ✏️ Sửa
                                </a>
                                <form id="del-role-@role.Id"
                                      asp-action="DeleteRole"
                                      method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@role.Id" />
                                    <button type="button" class="btn-delete"
                                            onclick="confirmDelete('@role.Id', '@role.Name')">
                                        🗑️ Xoá
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-icon">🔐</div>
        <div class="modal-title">Xác nhận xoá</div>
        <div class="modal-msg">
            Bạn có chắc muốn xoá role<br>
            <span class="modal-name" id="modalName"></span>?
        </div>
        <div class="modal-note">Tất cả user có role này sẽ bị ảnh hưởng.</div>
        <div class="modal-actions">
            <button class="modal-btn-cancel" onclick="closeModal()">Huỷ</button>
            <button class="modal-btn-confirm" onclick="submitDelete()">Xoá</button>
        </div>
    </div>
</div>

<script>
    let currentRoleId = null;

    function confirmDelete(id, name) {
        currentRoleId = id;
        document.getElementById('modalName').textContent = name;
        document.getElementById('modalOverlay').classList.add('show');
    }

    function closeModal() {
        document.getElementById('modalOverlay').classList.remove('show');
        currentRoleId = null;
    }

    function submitDelete() {
        if (currentRoleId) {
            document.getElementById('del-role-' + currentRoleId).submit();
        }
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeModal();
    });
</script>