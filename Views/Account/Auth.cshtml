@{
    Layout = null;
}
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/auth.css" />
<link rel="icon" type="image/png" href="~/images/logo/pth-logo.png" />
<div class="auth-scene" id="authScene">
    <div class="auth-scene-inner">

        <!-- CARD LOGIN -->
        <div class="auth-card login-card">
            <form asp-controller="Account" asp-action="Login" method="post" id="login-form">
                @Html.AntiForgeryToken()
                <h1>Đăng nhập</h1>

                <div class="input-box">
                    <input name="Email" type="email" required placeholder=" " />
                    <label>Email</label>
                    <div class="line"></div>
                </div>

                <div class="input-box">
                    <input name="Password" type="password" id="loginPw" required placeholder=" " />
                    <label>Mật khẩu</label>
                    <div class="line"></div>
                    <button type="button" class="toggle-pw" onclick="togglePw('loginPw', this)">
                        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </button>
                </div>

                <button type="submit" class="btn">Đăng nhập</button>

                <div class="divider">
                    <span>hoặc</span>
                </div>

                <button type="button" class="btn-google" onclick="window.location.href='/Account/LoginWithGoogle'">
                    <svg viewBox="0 0 24 24" width="18" height="18">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" />
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                    </svg>
                    Tiếp tục với Google
                </button>

                <div class="form-footer">
                    <span>Chưa có tài khoản?</span>
                    <a onclick="showRegister()">Đăng ký</a>
                </div>
            </form>
        </div>

        <!-- CARD REGISTER -->
        <div class="auth-card register-card">
            <form asp-controller="Account" asp-action="Register" method="post" id="register-form">
                @Html.AntiForgeryToken()
                <h1>Đăng ký</h1>

                <div class="input-box">
                    <input name="Email" type="email" required placeholder=" " />
                    <label>Email</label>
                    <div class="line"></div>
                </div>

                <div class="input-box">
                    <input name="Password" type="password" id="regPw" required placeholder=" " />
                    <label>Mật khẩu</label>
                    <div class="line"></div>
                    <button type="button" class="toggle-pw" onclick="togglePw('regPw', this)">
                        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </button>
                </div>

                <div class="input-box">
                    <input name="ConfirmPassword" type="password" id="regConfirm" required placeholder=" " />
                    <label>Nhập lại mật khẩu</label>
                    <div class="line"></div>
                    <button type="button" class="toggle-pw" onclick="togglePw('regConfirm', this)">
                        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </button>
                </div>

                <button type="submit" class="btn">Đăng ký</button>

                <div class="form-footer">
                    <span>Đã có tài khoản?</span>
                    <a onclick="showLogin()">Đăng nhập</a>
                </div>
            </form>
        </div>

    </div>
</div>

<script src="~/js/auth.js"></script>
