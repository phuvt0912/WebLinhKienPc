@model IEnumerable<WebLinhKienPc.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    decimal total = 0;
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .cart-wrap {
        max-width: 100%;
        margin: 0 auto;
        padding: 40px 48px;
        box-sizing: border-box;
    }

    .page-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: #e8e8ff;
        margin: 0 0 28px;
        line-height: 1.2;
    }

    /* Empty state */
    .empty-cart {
        text-align: center;
        padding: 80px 0;
    }

    .empty-icon {
        font-size: 60px;
        margin-bottom: 16px;
        display: block;
    }

    .empty-text {
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        color: #6a6a9a;
        margin-bottom: 24px;
    }

    /* Table */
    .cart-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        margin-bottom: 32px;
        table-layout: fixed;
    }

        .cart-table th {
            text-align: left;
            padding: 14px 18px;
            background: rgba(162, 89, 255, 0.12);
            color: #c490ff;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            letter-spacing: 1px;
            font-size: 14px;
            border-bottom: 2px solid rgba(162, 89, 255, 0.3);
            white-space: nowrap;
        }
            /* Đặt width cố định cho từng cột */
            .cart-table th:nth-child(1) {
                width: 100px;
            }
            .cart-table th:nth-child(2) {
                width: auto;
            }
            .cart-table th:nth-child(3) {
                width: 160px;
            }
            .cart-table th:nth-child(4) {
                width: 160px;
            }
            .cart-table th:nth-child(5) {
                width: 180px;
            }
            .cart-table th:nth-child(6) {
                width: 100px;
            }

            .cart-table th.center,
            .cart-table td.center {
                text-align: center;
            }

        .cart-table td {
            padding: 16px 18px;
            color: #c0c0e0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            vertical-align: middle;
            overflow: hidden;
        }

        .cart-table tr:hover td {
            background: rgba(162, 89, 255, 0.03);
        }

    /* Product cell */
    .cart-img {
        width: 72px;
        height: 72px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid rgba(162, 89, 255, 0.2);
        background: #1a1a35;
        display: block;
        flex-shrink: 0;
    }

    .cart-img-empty {
        width: 72px;
        height: 72px;
        border-radius: 8px;
        border: 1px solid rgba(162, 89, 255, 0.15);
        background: #1a1a35;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: #3a3a5a;
    }

    .cart-name {
        font-weight: 500;
        color: #e8e8ff;
        font-size: 14px;
        line-height: 1.4;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .cart-price {
        font-family: 'Rajdhani', sans-serif;
        font-size: 17px;
        font-weight: 600;
        color: #a259ff;
        white-space: nowrap;
    }

    .cart-subtotal {
        font-family: 'Rajdhani', sans-serif;
        font-size: 17px;
        font-weight: 700;
        background: linear-gradient(135deg, #a259ff, #00cfff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        white-space: nowrap;
    }

    /* Quantity controls */
    .qty-wrap {
        display: inline-flex;
        align-items: center;
        background: #12122a;
        border: 1px solid rgba(162, 89, 255, 0.2);
        border-radius: 8px;
        overflow: hidden;
    }

    .qty-btn {
        width: 34px;
        height: 36px;
        background: none;
        border: none;
        color: #a259ff;
        font-size: 18px;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none !important;
    }

        .qty-btn:hover {
            background: rgba(162, 89, 255, 0.12);
        }

    .qty-num {
        padding: 0 14px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 17px;
        font-weight: 700;
        color: #e8e8ff;
        border-left: 1px solid rgba(162, 89, 255, 0.15);
        border-right: 1px solid rgba(162, 89, 255, 0.15);
        min-width: 36px;
        text-align: center;
        line-height: 36px;
    }

    /* Remove btn */
    .btn-remove {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 13px;
        padding: 6px 14px;
        border-radius: 6px;
        border: 1px solid rgba(255, 79, 123, 0.3);
        background: rgba(255, 79, 123, 0.06);
        color: #ff4f7b;
        text-decoration: none !important;
        transition: all 0.2s;
        white-space: nowrap;
        display: inline-block;
    }

        .btn-remove:hover {
            background: rgba(255, 79, 123, 0.15);
            border-color: #ff4f7b;
            color: #ff4f7b;
        }

    /* Summary */
    .cart-summary {
        background: #12122a;
        border: 1px solid rgba(162, 89, 255, 0.15);
        border-radius: 12px;
        padding: 24px 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
    }

    .summary-total-label {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        color: #6a6a9a;
        margin-bottom: 4px;
    }

    .summary-total-price {
        font-family: 'Rajdhani', sans-serif;
        font-size: 32px;
        font-weight: 700;
        background: linear-gradient(135deg, #a259ff, #00cfff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
    }

    .summary-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-continue {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 15px;
        letter-spacing: 0.8px;
        padding: 12px 24px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        color: #6a6a9a;
        text-decoration: none !important;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-continue:hover {
            border-color: rgba(162, 89, 255, 0.3);
            color: #c0c0e0;
        }

    .btn-checkout {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 15px;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 12px 28px;
        border-radius: 8px;
        border: none;
        background: linear-gradient(135deg, #6c2bd9, #a259ff);
        color: #fff;
        text-decoration: none !important;
        transition: opacity 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-checkout:hover {
            opacity: 0.85;
            color: #fff;
        }

    .btn-back-shop {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 15px;
        padding: 12px 24px;
        border-radius: 8px;
        border: 1px solid rgba(162, 89, 255, 0.4);
        background: rgba(162, 89, 255, 0.08);
        color: #a259ff;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .btn-back-shop:hover {
            background: rgba(162, 89, 255, 0.15);
            border-color: #a259ff;
            color: #c490ff;
        }

    .item-count {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        color: #6a6a9a;
        margin-bottom: 20px;
    }

        .item-count span {
            color: #a259ff;
            font-weight: 500;
        }
</style>

    <div class="cart-wrap">

        <h2 class="page-title"><i class="bi bi-cart3 me-2 text-info"></i> Giỏ Hàng</h2>

        @if (!Model.Any())
        {
            <div class="empty-cart">
                <span class="empty-icon"><i class="bi bi-cart-x text-muted"></i></span>
                <p class="empty-text">Giỏ hàng của bạn đang trống</p>
                <a asp-controller="Product" asp-action="Index" class="btn-back-shop">
                    Khám phá sản phẩm →
                </a>
            </div>
        }
        else
        {
            <div class="item-count">
                Có <span>@Model.Count()</span> sản phẩm trong giỏ
            </div>

            <table class="cart-table">
                <thead>
                    <tr>
                        <th>Ảnh</th>
                        <th>Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th class="center">Số lượng</th>
                        <th class="center">Thành tiền</th>
                        <th class="center">Xoá</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var itemTotal = item.Product.Price * item.Quantity;
                        total += itemTotal;

                        <tr>
                            <!-- Ảnh -->
                            <td>
                                @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                {
                                    <img src="@item.Product.ImageUrl" class="cart-img" alt="@item.Product.Name" />
                                }
                                else
                                {
                                    <div class="cart-img-empty"><i class="bi bi-image"></i></div>
                                }
                            </td>

                            <!-- Tên -->
                            <td>
                                <div class="cart-name">@item.Product.Name</div>
                            </td>

                            <!-- Giá -->
                            <td>
                                <span class="cart-price">@item.Product.Price.ToString("N0") ₫</span>
                            </td>

                            <!-- Số lượng -->
                            <td class="center">
                                <div class="qty-wrap">
                                    <a class="qty-btn"
                                       asp-controller="Cart"
                                       asp-action="Decrease"
                                       asp-route-id="@item.CartItemId">−</a>
                                    <span class="qty-num">@item.Quantity</span>
                                    <a class="qty-btn"
                                       asp-controller="Cart"
                                       asp-action="Increase"
                                       asp-route-id="@item.CartItemId">+</a>
                                </div>
                            </td>

                            <!-- Tổng -->
                            <td class="center">
                                <span class="cart-subtotal">@itemTotal.ToString("N0") ₫</span>
                            </td>

                            <!-- Xóa -->
                            <td class="center">
                                <a class="btn-remove"
                                       asp-controller="Cart"
                                       asp-action="Remove"
                                       asp-route-id="@item.CartItemId">
                                    <i class="bi bi-trash3-fill me-1"></i> Xoá
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Summary -->
            <div class="cart-summary">
                <div>
                    <div class="summary-total-label">Tổng cộng</div>
                    <div class="summary-total-price">@total.ToString("N0") ₫</div>
                </div>
                <div class="summary-actions">
                    <a asp-controller="Product" asp-action="Index" class="btn-continue">
                        ← Tiếp tục mua
                    </a>
                    <a asp-controller="Order" asp-action="Checkout" class="btn-checkout">
                        Đặt hàng →
                    </a>
                </div>
            </div>
        }
    </div>