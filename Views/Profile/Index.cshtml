@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> _um
@inject SignInManager<IdentityUser> _sm
@model IdentityUser
@{
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("NhanVien");
    Layout = isAdmin ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Trang cá nhân";
    var profile  = ViewBag.Profile as WebLinhKienPc.Models.UserProfile;
    var avatar   = profile?.AvatarUrl;
    var initial  = (Model.UserName ?? Model.Email ?? "U")[0].ToString().ToUpper();
    var userRoles = await _um.GetRolesAsync(Model);
    var roleName  = userRoles.FirstOrDefault();
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .pf-wrap {
        max-width: 960px;
        margin: 48px auto;
        padding: 0 28px;
        display: grid;
        grid-template-columns: 270px 1fr;
        gap: 28px;
        align-items: start;
    }

    /* ===== LEFT ===== */
    .pf-left {
        background: #12122a;
        border: 1px solid rgba(162,89,255,0.15);
        border-radius: 16px;
        padding: 36px 24px;
        text-align: center;
    }

    .pf-avatar-wrap {
        position: relative;
        display: inline-block;
        margin-bottom: 20px;
    }

    .pf-avatar-img {
        width: 110px; height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid rgba(162,89,255,0.4);
        display: block;
    }

    .pf-avatar-initial {
        width: 110px; height: 110px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6c2bd9, #a259ff);
        display: flex; align-items: center; justify-content: center;
        font-family: 'Rajdhani', sans-serif;
        font-size: 44px; font-weight: 700;
        color: #fff;
        border: 3px solid rgba(162,89,255,0.4);
        margin: 0 auto;
    }

    .pf-avatar-btn {
        position: absolute;
        bottom: 3px; right: 3px;
        width: 32px; height: 32px;
        border-radius: 50%;
        background: #a259ff;
        border: 2px solid #0d0d1a;
        color: #fff; font-size: 13px;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.2s;
    }

    .pf-avatar-btn:hover { background: #b274ff; }

    .pf-name {
        font-family: 'Rajdhani', sans-serif;
        font-size: 22px; font-weight: 700;
        color: #e8e8ff; margin-bottom: 6px;
    }

    .pf-email {
        font-family: 'Inter', sans-serif;
        font-size: 13px; color: #6a6a9a;
        margin-bottom: 16px;
        word-break: break-all;
    }

    .pf-role {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 16px;
        border-radius: 20px;
        font-family: 'Inter', sans-serif;
        font-size: 13px; font-weight: 500;
        border: 1px solid;
    }

    .btn-remove-avatar {
        display: block;
        margin: 16px auto 0;
        background: none; border: none;
        color: #ff4f7b;
        font-family: 'Inter', sans-serif;
        font-size: 13px; cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-remove-avatar:hover { opacity: 0.7; }

    /* ===== RIGHT ===== */
    .pf-right {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .pf-card {
        background: #12122a;
        border: 1px solid rgba(162,89,255,0.15);
        border-radius: 16px;
        overflow: hidden;
    }

    .pf-card-hdr {
        padding: 16px 26px;
        background: #1a1a35;
        border-bottom: 1px solid rgba(162,89,255,0.1);
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700; font-size: 17px;
        color: #e8e8ff; letter-spacing: 0.5px;
    }

    .pf-card-body { padding: 26px; }

    .field { margin-bottom: 20px; }
    .field:last-of-type { margin-bottom: 0; }

    .field label {
        display: block;
        font-family: 'Inter', sans-serif;
        font-size: 13px; color: #6a6a9a;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

    .field input {
        width: 100%;
        background: #0d0d1a;
        border: 1px solid rgba(162,89,255,0.2);
        border-radius: 10px;
        padding: 13px 18px;
        color: #e8e8ff;
        font-family: 'Inter', sans-serif;
        font-size: 15px; outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
    }

    .field input:focus {
        border-color: #a259ff;
        box-shadow: 0 0 0 3px rgba(162,89,255,0.1);
    }

    .field input::placeholder { color: #3a3a5a; }

    .pwd-wrap { position: relative; }
    .pwd-wrap input { padding-right: 48px; }

    .pwd-eye {
        position: absolute;
        right: 14px; top: 50%;
        transform: translateY(-50%);
        background: none; border: none;
        color: #6a6a9a; font-size: 16px;
        cursor: pointer; padding: 0;
        transition: color 0.2s;
    }

    .pwd-eye:hover { color: #a259ff; }

    .pwd-strength {
        display: flex; gap: 5px;
        margin-top: 8px;
    }

    .pwd-bar {
        height: 4px; flex: 1;
        border-radius: 2px;
        background: rgba(255,255,255,0.08);
        transition: background 0.3s;
    }

    .strength-label {
        font-size: 12px; color: #6a6a9a;
        margin-top: 5px; text-align: right;
        font-family: 'Inter', sans-serif;
    }

    .btn-save {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700; font-size: 15px;
        letter-spacing: 0.8px;
        padding: 12px 28px;
        border-radius: 10px; border: none;
        background: linear-gradient(135deg, #6c2bd9, #a259ff);
        color: #fff; cursor: pointer;
        transition: opacity 0.2s;
        margin-top: 20px;
    }

    .btn-save:hover { opacity: 0.85; }

    .alert {
        padding: 13px 18px;
        border-radius: 10px;
        font-family: 'Inter', sans-serif;
        font-size: 14px; margin-bottom: 18px;
    }

    .alert-success {
        background: rgba(76,223,138,0.08);
        border: 1px solid rgba(76,223,138,0.25);
        color: #4cdf8a;
    }

    .alert-error {
        background: rgba(255,79,123,0.08);
        border: 1px solid rgba(255,79,123,0.25);
        color: #ff4f7b;
    }

    @@media (max-width: 700px) {
        .pf-wrap { grid-template-columns: 1fr; }
    }
</style>

<div class="pf-wrap">

    <!-- ===== LEFT: AVATAR ===== -->
    <div class="pf-left">
        <form asp-action="UpdateAvatar" method="post"
              enctype="multipart/form-data" id="avatarForm">
            @Html.AntiForgeryToken()
            <div class="pf-avatar-wrap">
                @if (!string.IsNullOrEmpty(avatar))
                {
                    <img src="@avatar" class="pf-avatar-img" alt="Avatar" id="avatarPreview" />
                }
                else
                {
                    <div class="pf-avatar-initial" id="avatarInitial">@initial</div>
                }
                <button type="button" class="pf-avatar-btn"
                        onclick="document.getElementById('avatarInput').click()"
                        title="Đổi ảnh">✏️</button>
            </div>
            <input type="file" id="avatarInput" name="avatar"
                   accept="image/*" style="display:none"
                   onchange="previewAndSubmit(this)" />
        </form>

        <div class="pf-name">@Model.UserName</div>
        <div class="pf-email">@Model.Email</div>

        @* Role badge giống _Header *@
        @if (roleName == "Admin")
        {
            <span class="pf-role" style="background:rgba(162,89,255,0.1);border-color:rgba(162,89,255,0.3);color:#a259ff">
                ⚡ Quản trị viên
            </span>
        }
        else if (roleName == "NhanVien")
        {
            <span class="pf-role" style="background:rgba(0,207,255,0.08);border-color:rgba(0,207,255,0.3);color:#00cfff">
                🔧 Nhân viên
            </span>
        }
        else
        {
            <span class="pf-role" style="background:rgba(162,89,255,0.06);border-color:rgba(162,89,255,0.2);color:#6a6a9a">
                👤 Khách hàng
            </span>
        }

        @if (!string.IsNullOrEmpty(avatar))
        {
            <form asp-action="RemoveAvatar" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-remove-avatar">
                    🗑 Xóa ảnh đại diện
                </button>
            </form>
        }
    </div>

    <!-- ===== RIGHT ===== -->
    <div class="pf-right">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">✅ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">❌ @TempData["Error"]</div>
        }

        <!-- Card: Thông tin -->
        <div class="pf-card">
            <div class="pf-card-hdr">Thông tin tài khoản</div>
            <div class="pf-card-body">
                <form asp-action="UpdateInfo" method="post">
                    @Html.AntiForgeryToken()
                    <div class="field">
                        <label>Username</label>
                        <input type="text" name="username"
                               value="@Model.UserName"
                               placeholder="Tên hiển thị..." />
                    </div>
                    <div class="field">
                        <label>Email</label>
                        <input type="email" name="email"
                               value="@Model.Email"
                               placeholder="email@example.com" />
                    </div>
                    <button type="submit" class="btn-save">Lưu thông tin</button>
                </form>
            </div>
        </div>

        <!-- Card: Đổi mật khẩu -->
        <div class="pf-card">
            <div class="pf-card-hdr">Đổi mật khẩu</div>
            <div class="pf-card-body">

                @if (TempData["PwdSuccess"] != null)
                {
                    <div class="alert alert-success">✅ @TempData["PwdSuccess"]</div>
                }
                @if (TempData["PwdError"] != null)
                {
                    <div class="alert alert-error">❌ @TempData["PwdError"]</div>
                }

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="field">
                        <label>Mật khẩu hiện tại</label>
                        <div class="pwd-wrap">
                            <input type="password" name="currentPassword"
                                   id="curPwd"
                                   placeholder="Nhập mật khẩu hiện tại..." />
                            <button type="button" class="pwd-eye"
                                    onclick="togglePwd('curPwd',this)">👁</button>
                        </div>
                    </div>

                    <div class="field">
                        <label>Mật khẩu mới</label>
                        <div class="pwd-wrap">
                            <input type="password" name="newPassword"
                                   id="newPwd"
                                   placeholder="Tối thiểu 6 ký tự..."
                                   oninput="checkStrength(this.value)" />
                            <button type="button" class="pwd-eye"
                                    onclick="togglePwd('newPwd',this)">👁</button>
                        </div>
                        <div class="pwd-strength">
                            <div class="pwd-bar" id="bar1"></div>
                            <div class="pwd-bar" id="bar2"></div>
                            <div class="pwd-bar" id="bar3"></div>
                            <div class="pwd-bar" id="bar4"></div>
                        </div>
                        <div class="strength-label" id="strengthLabel"></div>
                    </div>

                    <div class="field">
                        <label>Xác nhận mật khẩu mới</label>
                        <div class="pwd-wrap">
                            <input type="password" name="confirmPassword"
                                   id="confirmPwd"
                                   placeholder="Nhập lại mật khẩu mới..."
                                   oninput="checkMatch()" />
                            <button type="button" class="pwd-eye"
                                    onclick="togglePwd('confirmPwd',this)">👁</button>
                        </div>
                    </div>

                    <button type="submit" class="btn-save">Đổi mật khẩu</button>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function previewAndSubmit(input) {
        if (!input.files[0]) return;
        const reader = new FileReader();
        reader.onload = e => {
            // Cập nhật avatar trong profile
            const wrap = document.querySelector('.pf-avatar-wrap');
            let img = document.getElementById('avatarPreview');
            if (!img) {
                img = document.createElement('img');
                img.id        = 'avatarPreview';
                img.className = 'pf-avatar-img';
                img.alt       = 'Avatar';
                const initial = document.getElementById('avatarInitial');
                if (initial) initial.replaceWith(img);
                else wrap.prepend(img);
            }
            img.src = e.target.result;

            // Cập nhật avatar trên Header luôn
            const headerAvatar = document.querySelector('.pc-avatar');
            if (headerAvatar) {
                const avatarImg = document.createElement('img');
                avatarImg.src   = e.target.result;
                avatarImg.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:8px;';
                headerAvatar.innerHTML = '';
                headerAvatar.appendChild(avatarImg);
            }
        };
        reader.readAsDataURL(input.files[0]);
        document.getElementById('avatarForm').submit();
    }

    function togglePwd(id, btn) {
        const input = document.getElementById(id);
        const show  = input.type === 'password';
        input.type  = show ? 'text' : 'password';
        btn.textContent = show ? '🙈' : '👁';
    }

    function checkStrength(val) {
        const colors = ['#ff4f7b','#ffaa00','#00cfff','#4cdf8a'];
        const labels = ['Yếu','Trung bình','Khá','Mạnh'];
        let score = 0;
        if (val.length >= 6)  score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;

        [1,2,3,4].forEach(i => {
            document.getElementById('bar'+i).style.background =
                i <= score ? colors[score-1] : 'rgba(255,255,255,0.08)';
        });

        const lbl = document.getElementById('strengthLabel');
        lbl.textContent = val.length > 0 ? (labels[score-1] || '') : '';
        lbl.style.color = val.length > 0 ? colors[score-1] : '#6a6a9a';
        checkMatch();
    }

    function checkMatch() {
        const newVal = document.getElementById('newPwd').value;
        const cfm    = document.getElementById('confirmPwd');
        if (!cfm.value) {
            cfm.style.borderColor = 'rgba(162,89,255,0.2)';
            cfm.style.boxShadow   = 'none';
            return;
        }
        const ok = newVal === cfm.value;
        cfm.style.borderColor = ok ? '#4cdf8a' : '#ff4f7b';
        cfm.style.boxShadow   = ok
            ? '0 0 0 3px rgba(76,223,138,0.1)'
            : '0 0 0 3px rgba(255,79,123,0.1)';
    }
</script>