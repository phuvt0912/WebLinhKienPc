@using WebLinhKienPc.ViewModels
@model ProductAdminViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminCategory/Index.css" />
<link rel="stylesheet" href="~/css/AdminProduct/Index.css" />


<div class="page-wrap">
    <div class="page-header">
        <h2 class="page-title">Quản Lý Sản Phẩm</h2>
        <a class="btn-add" 
           asp-action="CreateProduct" 
           asp-route-keyword="@Model.Keyword" 
           asp-route-categoryId="@Model.CategoryId">
            + Thêm sản phẩm
        </a>
    </div>

    <div class="total-count">
        Tổng cộng <span>@Model.Products.Count()</span> sản phẩm
    </div>

    <!-- Filter -->
    <form method="get">
        <div class="filter-bar">
            <input class="filter-input"
                   name="keyword"
                   value="@Model.Keyword"
                   placeholder="Tìm tên sản phẩm..." />

            <select class="filter-select"
                    name="categoryId"
                    asp-items="Model.Categories">
                <option value="">Tất cả danh mục</option>
            </select>

            <button type="submit" class="btn-filter">🔍 Lọc</button>

            @if (!string.IsNullOrEmpty(Model.Keyword) || Model.CategoryId != null)
            {
                <a asp-action="Index" class="btn-filter" style="border-color:rgba(255,79,123,0.3);color:#ff4f7b;text-decoration:none">
                    ✕ Xoá lọc
                </a>
            }
        </div>
    </form>

    <!-- Table -->
    <table class="prod-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Ảnh</th>
                <th>Tên Sản Phẩm</th>
                <th>Danh Mục</th>
                <th>Giá</th>
                <th>Tồn Kho</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <span class="empty-icon">📦</span>
                            Chưa có sản phẩm nào
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var p in Model.Products)
                {
                    <tr>
                        <td class="prod-id">#@p.ProductId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" class="prod-img" alt="@p.Name" />
                            }
                            else
                            {
                                <div class="prod-img-empty">📷</div>
                            }
                        </td>
                        <td>
                            <span class="prod-name" title="@p.Name">@p.Name</span>
                        </td>
                        <td>
                            @if (p.Category != null)
                            {
                                <span class="prod-category">@p.Category.Name</span>
                            }
                            else
                            {
                                <span style="color:#3a3a5a">—</span>
                            }
                        </td>
                        <td class="prod-price">@p.Price.ToString("N0") VNĐ</td>
                        <td class="prod-stock">
                            @{
                                var stockClass = p.Stock > 10 ? "stock-ok" : p.Stock > 0 ? "stock-low" : "stock-out";
                                var stockLabel = p.Stock > 0 ? p.Stock.ToString() : "Hết hàng";
                            }
                            <span class="@stockClass">@stockLabel</span>
                        </td>
                        <td>
                            <div class="action-wrap">
                                <a class="btn-edit"
                                   asp-action="EditProduct"
                                   asp-route-id="@p.ProductId"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-categoryId="@Model.CategoryId">
                                    ✏️ Sửa
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-action="DeleteProduct"
                                          method="post"
                                          id="form-@p.ProductId"
                                          style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.ProductId" />
                                        <input type="hidden" name="keyword" value="@Model.Keyword" />
                                        <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                                        <button type="button"
                                                class="btn-delete"
                                                onclick="confirmDelete(@p.ProductId, '@p.Name')">
                                            🗑️ Xoá
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-icon">🗑️</div>
        <div class="modal-title">Xác nhận xoá</div>
        <div class="modal-msg">
            Bạn có chắc muốn xoá sản phẩm<br>
            <span class="modal-name" id="modalName"></span>?
        </div>
        <div class="modal-note">Hành động này không thể hoàn tác.</div>
        <div class="modal-actions">
            <button class="modal-btn-cancel" onclick="closeModal()">Huỷ</button>
            <button class="modal-btn-confirm" onclick="submitDelete()">Xoá</button>
        </div>
    </div>
</div>

<script>
    let currentFormId = null;

    function confirmDelete(id, name) {
        currentFormId = id;
        document.getElementById('modalName').textContent = name;
        document.getElementById('modalOverlay').classList.add('show');
    }

    function closeModal() {
        document.getElementById('modalOverlay').classList.remove('show');
        currentFormId = null;
    }

    function submitDelete() {
        if (currentFormId) {
            document.getElementById('form-' + currentFormId).submit();
        }
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeModal();
    });
</script>