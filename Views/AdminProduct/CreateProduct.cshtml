@model WebLinhKienPc.Models.Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lí sản phẩm";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminProduct/create-product.css" />


<div class="form-wrap">
    <div class="page-header">
        <h2 class="page-title">Thêm Sản Phẩm</h2>
        <p class="page-sub">Điền thông tin để tạo sản phẩm mới</p>
    </div>

    <form asp-action="CreateProduct" method="post" enctype="multipart/form-data" id="createForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnKeyword" value="@ViewBag.Keyword" />
        <input type="hidden" name="returnCategoryId" value="@ViewBag.CategoryIdRef" />
        <input type="hidden" name="returnStockStatus" value="@ViewBag.StockStatus" />

        <div class="form-grid">
            <!-- Tên sản phẩm -->
            <div class="field full">
                <div class="field-header">
                    <label>Tên sản phẩm <span style="color:#ff4f7b">*</span></label>
                </div>
                <input asp-for="Name" placeholder="VD: Intel Core i9-14900K..." autocomplete="off" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="divider"></div>

            <!-- Giá -->
            <div class="field">
                <div class="field-header">
                    <label>Giá (VNĐ) <span style="color:#ff4f7b">*</span></label>
                </div>
                <input asp-for="Price" 
                       type="text"
                       inputmode="numeric"
                       pattern="[0-9.]*"
                       min="0" 
                       placeholder="VD: 12.500.000"
                       id="priceInput" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <!-- Số lượng -->
            <div class="field">
                <div class="field-header">
                    <label>Số lượng tồn kho <span style="color:#ff4f7b">*</span></label>
                </div>
                <input asp-for="Stock" type="number" min="0" placeholder="VD: 50" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <!-- Danh mục -->
            <div class="field">
                <div class="field-header">
                    <label>Danh mục <span style="color:#ff4f7b">*</span></label>
                </div>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <!-- Ảnh sản phẩm -->
            <div class="field">
                <div class="field-header">
                    <label>Ảnh sản phẩm</label>
                </div>

                <div class="img-tabs">
                    <button type="button" class="img-tab active" onclick="switchTab('url', this)">🔗 URL</button>
                    <button type="button" class="img-tab" onclick="switchTab('file', this)">📁 Tải lên</button>
                </div>

                <!-- Tab URL -->
                <div id="tab-url">
                    <input asp-for="ImageUrl"
                           id="imageUrlInput"
                           placeholder="https://..."
                           oninput="previewImage(this.value)"
                           autocomplete="off" />
                </div>

                <!-- Tab File (ĐÃ SỬA) -->
                <div id="tab-file" style="display:none">
                    <div class="upload-area" id="uploadArea">
                        <span class="upload-icon">📁</span>
                        <span class="upload-text">Kéo thả hoặc click để chọn ảnh</span>
                        <span class="upload-sub">PNG, JPG, WEBP — tối đa 5MB</span>
                    </div>
                    <input type="file"
                           name="imageFile"
                           id="imageFileInput"
                           accept="image/*"
                           style="display:none" />
                </div>

                <!-- Preview -->
                <div class="img-preview-wrap" id="imgPreviewWrap">
                    <img id="imgPreview" class="img-preview" src="" alt="Preview" />
                    <button type="button" class="img-clear" onclick="clearImage()">✕</button>
                </div>
            </div>

            <div class="divider"></div>

            <!-- Mô tả -->
            <div class="field full">
                <div class="field-header">
                    <label>Mô tả sản phẩm</label>
                    <span class="char-count" id="charCount">0 / 1000</span>
                </div>
                <textarea asp-for="Description"
                          placeholder="Mô tả chi tiết sản phẩm..."
                          oninput="updateCharCount(this.value)"
                          maxlength="1000"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-submit" id="submitBtn">+ Thêm sản phẩm</button>
                <a asp-action="Index" 
                   asp-route-keyword="@ViewBag.Keyword" 
                   asp-route-categoryId="@ViewBag.CategoryIdRef" 
                   asp-route-stockStatus="@ViewBag.StockStatus"
                   class="btn-back">← Quay lại</a>
            </div>
        </div>
        <!-- Hiển thị lỗi tổng quát nếu có -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" style="background: rgba(255, 79, 123, 0.1); border: 1px solid #ff4f7b; color: #ff4f7b; padding: 12px; border-radius: 8px; margin-top: 20px; grid-column: 1 / -1;">
                <strong>Vui lòng kiểm tra lại:</strong>
                <ul style="margin-top: 8px; margin-bottom: 0;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }
    </form>
</div>

<script>
    // ===== FORMAT GIÁ TIỀN =====
    const priceInput = document.getElementById('priceInput');
    if (priceInput) {
        priceInput.addEventListener('input', function(e) {
            const cursorPos = this.selectionStart;
            let rawValue = this.value.replace(/\./g, '');
            
            if (!rawValue) {
                this.value = '';
                return;
            }
            
            const textBeforeCursor = this.value.substring(0, cursorPos);
            const digitsBeforeCursor = textBeforeCursor.replace(/\./g, '').length;
            
            const formattedValue = Number(rawValue).toLocaleString('vi-VN');
            this.value = formattedValue;
            
            let newCursorPos = 0;
            let digitCount = 0;
            
            for (let i = 0; i < formattedValue.length; i++) {
                if (formattedValue[i] >= '0' && formattedValue[i] <= '9') {
                    digitCount++;
                    if (digitCount === digitsBeforeCursor) {
                        newCursorPos = i + 1;
                        break;
                    }
                }
            }
            
            if (newCursorPos === 0) newCursorPos = formattedValue.length;
            this.setSelectionRange(newCursorPos, newCursorPos);
        });

        priceInput.addEventListener('keydown', function(e) {
            if (e.key === 'Backspace') {
                const cursorPos = this.selectionStart;
                const value = this.value;
                
                if (cursorPos > 0 && value[cursorPos - 1] === '.' && this.selectionStart === this.selectionEnd) {
                    e.preventDefault();
                    
                    let newPos = cursorPos - 1;
                    while (newPos > 0 && value[newPos - 1] === '.') {
                        newPos--;
                    }
                    
                    const newValue = value.substring(0, newPos) + value.substring(cursorPos);
                    this.value = newValue;
                    this.setSelectionRange(newPos, newPos);
                    this.dispatchEvent(new Event('input'));
                }
            }
        });
    }

    // ===== XỬ LÝ SUBMIT =====
    document.getElementById('createForm').addEventListener('submit', function() {
        const priceInput = document.getElementById('priceInput');
        if (priceInput) {
            priceInput.value = priceInput.value.replace(/\./g, '');
        }
        
        const btn = document.getElementById('submitBtn');
        btn.textContent = 'Đang lưu...';
        btn.disabled = true;
    });

    // ===== CHUYỂN TAB =====
    function switchTab(tab, btn) {
        document.querySelectorAll('.img-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-url').style.display = tab === 'url' ? 'block' : 'none';
        document.getElementById('tab-file').style.display = tab === 'file' ? 'block' : 'none';
        clearImage();
        
        if (tab === 'file') {
            const fileInput = document.getElementById('imageFileInput');
            if (fileInput) fileInput.value = '';
        }
    }

    // ===== PREVIEW IMAGE TỪ URL =====
    function previewImage(url) {
        const wrap = document.getElementById('imgPreviewWrap');
        const img = document.getElementById('imgPreview');
        
        if (url && url.trim()) {
            img.src = url.trim();
            img.onload = () => wrap.classList.add('show');
            img.onerror = () => {
                wrap.classList.remove('show');
                img.src = '';
            };
        } else {
            wrap.classList.remove('show');
            img.src = '';
        }
    }

    // ===== PREVIEW IMAGE TỪ FILE =====
    function previewFile(input) {
        if (!input.files || !input.files[0]) return;
        
        const file = input.files[0];
        
        if (file.size > 5 * 1024 * 1024) {
            alert('Ảnh không được vượt quá 5MB');
            input.value = '';
            return;
        }
        
        if (!file.type.startsWith('image/')) {
            alert('Vui lòng chọn file ảnh');
            input.value = '';
            return;
        }
        
        const reader = new FileReader();
        reader.onload = e => {
            const img = document.getElementById('imgPreview');
            const wrap = document.getElementById('imgPreviewWrap');
            img.src = e.target.result;
            wrap.classList.add('show');
            
            const uploadText = document.querySelector('.upload-text');
            if (uploadText) {
                uploadText.textContent = file.name.length > 30 ? file.name.substring(0, 27) + '...' : file.name;
            }
        };
        reader.readAsDataURL(file);
    }

    // ===== XOÁ PREVIEW =====
    function clearImage() {
        const img = document.getElementById('imgPreview');
        const wrap = document.getElementById('imgPreviewWrap');
        
        img.src = '';
        wrap.classList.remove('show');
        
        const urlInput = document.getElementById('imageUrlInput');
        if (urlInput) urlInput.value = '';
        
        const fileInput = document.getElementById('imageFileInput');
        if (fileInput) {
            fileInput.value = '';
            const uploadText = document.querySelector('.upload-text');
            if (uploadText) {
                uploadText.textContent = 'Kéo thả hoặc click để chọn ảnh';
            }
        }
    }

    // ===== DRAG & DROP (ĐÃ SỬA) =====
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('imageFileInput');

    if (uploadArea && fileInput) {
        // Click để mở file dialog
        uploadArea.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            fileInput.click();
        });

        // Xử lý khi chọn file
        fileInput.addEventListener('change', function(e) {
            e.preventDefault();
            e.stopPropagation();
            if (this.files && this.files[0]) {
                previewFile(this);
            }
        });

        // Xử lý drag & drop
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            uploadArea.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }

        uploadArea.addEventListener('dragenter', () => uploadArea.classList.add('dragover'));
        uploadArea.addEventListener('dragover', () => uploadArea.classList.add('dragover'));
        uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));

        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            e.stopPropagation();
            uploadArea.classList.remove('dragover');
            
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const dt = new DataTransfer();
                dt.items.add(file);
                fileInput.files = dt.files;
                previewFile(fileInput);
            } else {
                alert('Vui lòng thả file ảnh');
            }
        });
    }

    // ===== ĐẾM KÝ TỰ =====
    function updateCharCount(val) {
        const el = document.getElementById('charCount');
        const len = val.length;
        el.textContent = len + ' / 1000';
        el.className = 'char-count';
        
        if (len > 800) el.classList.add('warn');
        if (len >= 1000) el.classList.add('over');
    }

    // ===== KHỞI TẠO =====
    document.addEventListener('DOMContentLoaded', function() {
        const descArea = document.querySelector('textarea[name="Description"]');
        if (descArea && descArea.value) updateCharCount(descArea.value);
        
        const nameInput = document.querySelector('input[name="Name"]');
        if (nameInput) nameInput.focus();
    });
</script>