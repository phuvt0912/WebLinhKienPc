@model WebLinhKienPc.Models.Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/AdminProduct/edit-product.css" />


<div class="form-wrap">

    <div class="page-header">
        <h2 class="page-title">Sửa Sản Phẩm</h2>
        <p class="page-sub">Chỉnh sửa thông tin sản phẩm</p>
    </div>

    <div class="edit-info">
        Đang sửa: <span>#@Model.ProductId — @Model.Name</span>
    </div>

    <form asp-action="EditProduct" method="post"
          enctype="multipart/form-data" id="editForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ProductId" />

        <!-- Hidden lưu URL gốc để restore khi cần -->
        <input type="hidden" id="originalImageUrl" name="OriginalImageUrl" value="@Model.ImageUrl" />
        <input type="hidden" name="returnKeyword" value="@ViewBag.Keyword" />
        <input type="hidden" name="returnCategoryId" value="@ViewBag.CategoryIdRef" />
        <input type="hidden" name="returnStockStatus" value="@ViewBag.StockStatus" />

        <div class="form-grid">

            <div class="field full">
                <div class="field-header">
                    <label>Tên sản phẩm <span style="color:#ff4f7b">*</span></label>
                </div>
                <input asp-for="Name" autocomplete="off" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="divider"></div>

            <div class="field">
                <div class="field-header">
                    <label>Giá (VNĐ) <span style="color:#ff4f7b">*</span></label>
                </div>
                <input asp-for="Price"
                       type="text"
                       inputmode="numeric"
                       id="priceInput"
                       placeholder="VD: 12500000" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="field">
                <div class="field-header">
                    <label>Số lượng tồn kho <span style="color:#ff4f7b">*</span></label>
                </div>
                <input asp-for="Stock"
                       type="text"
                       inputmode="numeric"
                       placeholder="VD: 50" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <div class="field">
                <div class="field-header">
                    <label>Danh mục <span style="color:#ff4f7b">*</span></label>
                </div>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="field">
                <div class="field-header">
                    <label>Ảnh sản phẩm</label>
                </div>

                <div class="img-tabs">
                    <button type="button" class="img-tab active" onclick="switchTab('url', this)">
                        🔗 URL
                    </button>
                    <button type="button" class="img-tab" onclick="switchTab('file', this)">
                        📁 Tải lên
                    </button>
                </div>

                <div id="tab-url">
                    <input asp-for="ImageUrl"
                           id="imageUrlInput"
                           placeholder="https://..."
                           oninput="previewImage(this.value)"
                           autocomplete="off" />
                </div>

                <div id="tab-file" style="display:none">
                    <label class="upload-area" id="uploadArea">
                        <input type="file"
                               name="imageFile"
                               id="imageFileInput"
                               accept="image/*"
                               style="display:none"
                               onchange="previewFile(this)" />
                        <span class="upload-icon">📁</span>
                        <span class="upload-text">Kéo thả hoặc click để chọn ảnh</span>
                        <span class="upload-sub">PNG, JPG, WEBP — tối đa 5MB</span>
                    </label>
                </div>

                <div class="img-preview-wrap @(!string.IsNullOrEmpty(Model.ImageUrl) ? "show" : "")"
                     id="imgPreviewWrap">
                    <img id="imgPreview"
                         class="img-preview"
                         src="@Model.ImageUrl"
                         alt="Preview" />
                    <button type="button" class="img-clear" onclick="clearImage()">✕</button>
                </div>
            </div>

            <div class="divider"></div>

            <div class="field full">
                <div class="field-header">
                    <label>Mô tả sản phẩm</label>
                    <span class="char-count" id="charCount">
                        @(Model.Description?.Length ?? 0) / 1000
                    </span>
                </div>
                <textarea asp-for="Description"
                          placeholder="Mô tả chi tiết sản phẩm..."
                          oninput="updateCharCount(this.value)"
                          maxlength="1000"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit" id="submitBtn">
                    ✏️ Lưu thay đổi
                </button>
                <a asp-action="Index" 
                   asp-route-keyword="@ViewBag.Keyword" 
                   asp-route-categoryId="@ViewBag.CategoryIdRef" 
                   asp-route-stockStatus="@ViewBag.StockStatus"
                   class="btn-back">← Quay lại</a>
            </div>

        </div>
    </form>
</div>

<script>
    // ===== TABS =====
    function switchTab(tab, btn) {
        document.querySelectorAll('.img-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-url').style.display = tab === 'url' ? 'block' : 'none';
        document.getElementById('tab-file').style.display = tab === 'file' ? 'block' : 'none';
    }

    // ===== PREVIEW =====
    function previewImage(url) {
        const wrap = document.getElementById('imgPreviewWrap');
        const img = document.getElementById('imgPreview');
        if (url.trim()) {
            img.src = url;
            img.onload = () => wrap.classList.add('show');
            img.onerror = () => wrap.classList.remove('show');
        } else {
            wrap.classList.remove('show');
        }
    }

    function previewFile(input) {
        if (!input.files || !input.files[0]) return;
        const file = input.files[0];
        if (file.size > 5 * 1024 * 1024) {
            alert('Ảnh không được vượt quá 5MB');
            input.value = '';
            return;
        }
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('imgPreview').src = e.target.result;
            document.getElementById('imgPreviewWrap').classList.add('show');
            document.querySelector('.upload-text').textContent = file.name;
        };
        reader.readAsDataURL(file);
    }

    function clearImage() {
        const isUrlTab = document.getElementById('tab-url').style.display !== 'none';
        if (isUrlTab) {
            const urlInput = document.getElementById('imageUrlInput');
            if (urlInput) urlInput.value = '';
        } else {
            const fileInput = document.getElementById('imageFileInput');
            if (fileInput) fileInput.value = '';
            const uploadText = document.querySelector('.upload-text');
            if (uploadText) uploadText.textContent = 'Kéo thả hoặc click để chọn ảnh';
        }
        document.getElementById('imgPreview').src = '';
        document.getElementById('imgPreviewWrap').classList.remove('show');
    }

    // ===== DRAG DROP =====
    const uploadArea = document.getElementById('uploadArea');
    if (uploadArea) {
        uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('dragover'); });
        uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
        uploadArea.addEventListener('drop', e => {
            e.preventDefault();
            uploadArea.classList.remove('dragover');
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const dt = new DataTransfer();
                dt.items.add(file);
                document.getElementById('imageFileInput').files = dt.files;
                previewFile(document.getElementById('imageFileInput'));
            }
        });
    }

    // ===== FORMAT GIÁ =====
    const priceInput = document.getElementById('priceInput');
    if (priceInput) {
        // Format khi load — bỏ phần thập phân
        const intPrice = Math.round(parseFloat(priceInput.value) || 0);
        priceInput.value = intPrice > 0 ? intPrice.toLocaleString('vi-VN') : '';

        // Cho phép sửa ở giữa — giữ cursor position
        priceInput.addEventListener('input', function () {
            const cursorPos = this.selectionStart;
            const prevLen = this.value.length;
            const dotsBeforeCursor = (this.value.substring(0, cursorPos).match(/\./g) || []).length;

            const raw = this.value.replace(/\D/g, '');
            const formatted = raw ? Number(raw).toLocaleString('vi-VN') : '';
            this.value = formatted;

            // Tính lại cursor sau khi format
            const newDotsBeforeCursor = (formatted.substring(0, cursorPos).match(/\./g) || []).length;
            const dotDiff = newDotsBeforeCursor - dotsBeforeCursor;
            const newPos = Math.max(0, Math.min(cursorPos + dotDiff, formatted.length));
            this.setSelectionRange(newPos, newPos);
        });
    }

    // ===== ĐẾM KÝ TỰ =====
    function updateCharCount(val) {
        const el = document.getElementById('charCount');
        const len = val.length;
        el.textContent = len + ' / 1000';
        el.className = 'char-count';
        if (len > 800) el.classList.add('warn');
        if (len >= 1000) el.classList.add('over');
    }

    // ===== SUBMIT =====
    document.getElementById('editForm').addEventListener('submit', function () {
        // 1. Bỏ format giá
        if (priceInput) {
            priceInput.value = priceInput.value.replace(/\./g, '').replace(/,/g, '');
        }

        // 2. Xử lý ảnh
        const isFileTab = document.getElementById('tab-file').style.display !== 'none';
        const fileInput = document.getElementById('imageFileInput');
        const urlInput = document.getElementById('imageUrlInput');
        const originalUrl = document.getElementById('originalImageUrl').value;

        if (isFileTab) {
            if (!fileInput || fileInput.files.length === 0) {
                // Tab File nhưng không chọn file → restore URL gốc
                if (urlInput) urlInput.value = originalUrl;
            } else {
                // Có file mới → xóa URL
                if (urlInput) urlInput.value = '';
            }
        }
        // Tab URL → gửi bình thường

        // 3. Loading
        const btn = document.getElementById('submitBtn');
        btn.textContent = 'Đang lưu...';
        btn.disabled = true;
    });
</script>