@model WebLinhKienPc.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<style>
    .od-wrap { padding: 28px 36px; max-width: 1100px; }

    .od-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .od-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: #e8e8ff;
        margin: 0;
    }

    .od-title span { color: #a259ff; }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        white-space: nowrap;
    }

    .status-pending   { background:rgba(255,170,0,0.12);  color:#ffaa00; border:1px solid rgba(255,170,0,0.25); }
    .status-shipping  { background:rgba(0,207,255,0.1);   color:#00cfff; border:1px solid rgba(0,207,255,0.25); }
    .status-completed { background:rgba(76,223,138,0.1);  color:#4cdf8a; border:1px solid rgba(76,223,138,0.25); }
    .status-cancelled { background:rgba(255,79,123,0.1);  color:#ff4f7b; border:1px solid rgba(255,79,123,0.25); }

    /* Info grid */
    .od-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
    }

    .od-card {
        background: #12122a;
        border: 1px solid rgba(162,89,255,0.15);
        border-radius: 12px;
        padding: 20px 24px;
    }

    .od-card-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: #a259ff;
        letter-spacing: 0.8px;
        margin-bottom: 14px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(162,89,255,0.1);
    }

    .od-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 10px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
    }

    .od-row:last-child { margin-bottom: 0; }

    .od-label { color: #6a6a9a; flex-shrink: 0; }
    .od-value { color: #e8e8ff; font-weight: 500; text-align: right; }

    /* Products table */
    .od-products {
        background: #12122a;
        border: 1px solid rgba(162,89,255,0.15);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .od-products-title {
        padding: 16px 22px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: #a259ff;
        letter-spacing: 0.8px;
        border-bottom: 1px solid rgba(162,89,255,0.15);
        background: rgba(162,89,255,0.05);
    }

    .od-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
    }

    .od-table th {
        padding: 12px 20px;
        background: rgba(162,89,255,0.08);
        color: #8888aa;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        border-bottom: 1px solid rgba(162,89,255,0.1);
        white-space: nowrap;
    }

    .od-table td {
        padding: 14px 20px;
        color: #c0c0e0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        vertical-align: middle;
    }

    .od-table tr:last-child td { border-bottom: none; }
    .od-table tr:hover td { background: rgba(162,89,255,0.03); }

    .prod-img {
        width: 48px; height: 48px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid rgba(162,89,255,0.15);
        background: #0d0d1a;
    }

    .prod-img-empty {
        width: 48px; height: 48px;
        border-radius: 8px;
        border: 1px solid rgba(162,89,255,0.1);
        background: #1a1a35;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #3a3a5a;
    }

    .prod-name {
        font-weight: 500;
        color: #e8e8ff;
        font-size: 14px;
        line-height: 1.4;
    }

    .prod-price { color: #a259ff; font-weight: 500; white-space: nowrap; }

    .prod-qty {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
        background: rgba(162,89,255,0.1);
        border: 1px solid rgba(162,89,255,0.2);
        border-radius: 6px;
        font-weight: 600;
        color: #e8e8ff;
    }

    .prod-total {
        font-family: 'Rajdhani', sans-serif;
        font-size: 16px;
        font-weight: 700;
        background: linear-gradient(135deg, #a259ff, #00cfff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        white-space: nowrap;
    }

    /* Summary */
    .od-summary {
        background: #12122a;
        border: 1px solid rgba(162,89,255,0.15);
        border-radius: 12px;
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .od-summary-label {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        color: #6a6a9a;
    }

    .od-summary-price {
        font-family: 'Rajdhani', sans-serif;
        font-size: 28px;
        font-weight: 700;
        background: linear-gradient(135deg, #a259ff, #00cfff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Actions */
    .od-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-back {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 600;
        font-size: 15px;
        padding: 10px 22px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        color: #6a6a9a;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-back:hover {
        border-color: rgba(162,89,255,0.3);
        color: #c0c0e0;
    }

    .btn-status {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 0.5px;
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: opacity 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-ship    { background: linear-gradient(135deg, #0f7a8a, #00cfff); color: #fff; }
    .btn-done    { background: linear-gradient(135deg, #1a6b3a, #4cdf8a); color: #fff; }
    .btn-cancel  { background: linear-gradient(135deg, #c0003c, #ff4f7b); color: #fff; }

    .btn-status:hover { opacity: 0.85; }
    .btn-status:disabled { opacity: 0.4; cursor: not-allowed; }

    .od-toast {
    padding: 14px 20px;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    margin-bottom: 20px;
    animation: toastIn 0.3s ease;
}

.od-toast.success {
    background: rgba(76,223,138,0.08);
    border: 1px solid rgba(76,223,138,0.25);
    color: #4cdf8a;
}

.od-toast.error {
    background: rgba(255,79,123,0.08);
    border: 1px solid rgba(255,79,123,0.25);
    color: #ff4f7b;
}

@@keyframes toastIn {
    from { opacity:0; transform:translateY(-8px); }
    to   { opacity:1; transform:translateY(0); }
}

/* Modal */
.modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 9998;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
}

.modal-overlay.show { display: flex; }

.modal-box {
    background: #12122a;
    border: 1px solid rgba(255,79,123,0.25);
    border-radius: 16px;
    padding: 36px 32px;
    max-width: 400px;
    width: 90%;
    text-align: center;
    animation: modalPop 0.2s ease;
}

@@keyframes modalPop {
    from { transform:scale(0.92); opacity:0; }
    to   { transform:scale(1);    opacity:1; }
}

.modal-icon  { font-size: 40px; margin-bottom: 12px; }
.modal-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 20px; font-weight: 700;
    color: #e8e8ff; margin-bottom: 10px;
}

.modal-msg {
    font-family: 'Inter', sans-serif;
    font-size: 14px; color: #8888aa;
    line-height: 1.6; margin-bottom: 6px;
}

.modal-name { color: #ff4f7b; font-weight: 500; }

.modal-note {
    font-size: 12px; color: #6a6a9a;
    font-family: 'Inter', sans-serif;
    margin-bottom: 24px;
}

.modal-actions { display: flex; gap: 12px; justify-content: center; }

.modal-btn-back {
    padding: 10px 24px; border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent; color: #6a6a9a;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600; font-size: 15px;
    cursor: pointer; transition: all 0.2s;
}

.modal-btn-back:hover { border-color: rgba(162,89,255,0.3); color: #c0c0e0; }

.modal-btn-confirm {
    padding: 10px 24px; border-radius: 8px;
    border: none;
    background: linear-gradient(135deg, #c0003c, #ff4f7b);
    color: #fff;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700; font-size: 15px;
    cursor: pointer; transition: opacity 0.2s;
}

.modal-btn-confirm:hover { opacity: 0.85; }

    @@media (max-width: 768px) {
        .od-grid { grid-template-columns: 1fr; }
        .od-wrap { padding: 20px; }
    }
</style>

<div class="od-wrap">
        @if (TempData["Success"] != null)
    {
        <div class="od-toast success" id="toast">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="od-toast error" id="toast">❌ @TempData["Error"]</div>
    }
    <!-- Header -->
    <div class="od-header">
        <div>
            <h2 class="od-title">Đơn hàng <span>#@Model.OrderCode</span></h2>
            <div style="font-family:'Inter',sans-serif;font-size:13px;color:#6a6a9a;margin-top:4px">
                Đặt lúc @Model.OrderDate.ToString("HH:mm - dd/MM/yyyy")
            </div>
        </div>

        @{
            string statusClass = Model.Status switch {
                OrderStatus.Pending   => "status-pending",
                OrderStatus.Shipping  => "status-shipping",
                OrderStatus.Completed => "status-completed",
                OrderStatus.Cancelled => "status-cancelled",
                _ => "status-pending"
            };
            string statusLabel = Model.Status switch {
                OrderStatus.Pending   => "⏳ Chờ xử lý",
                OrderStatus.Shipping  => "🚚 Đang giao",
                OrderStatus.Completed => "✅ Hoàn thành",
                OrderStatus.Cancelled => "❌ Đã huỷ",
                _ => Model.Status.ToString()
            };
        }
        <span class="status-badge @statusClass">@statusLabel</span>
    </div>

    <!-- Info grid -->
    <div class="od-grid">
        <div class="od-card">
            <div class="od-card-title">📋 Thông tin đơn hàng</div>
            <div class="od-row">
                <span class="od-label">Mã đơn</span>
                <span class="od-value" style="color:#a259ff">#@Model.OrderCode</span>
            </div>
            <div class="od-row">
                <span class="od-label">Ngày đặt</span>
                <span class="od-value">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="od-row">
                <span class="od-label">Trạng thái</span>
                <span class="od-value">
                    <span class="status-badge @statusClass" style="font-size:11px;padding:3px 10px">@statusLabel</span>
                </span>
            </div>
            <div class="od-row">
                <span class="od-label">Tổng tiền</span>
                <span class="od-value" style="font-family:'Rajdhani',sans-serif;font-size:18px;color:#4cdf8a">
                    @Model.TotalPrice.ToString("N0") ₫
                </span>
            </div>
        </div>

        <div class="od-card">
            <div class="od-card-title">👤 Thông tin khách hàng</div>
            <div class="od-row">
                <span class="od-label">Họ tên</span>
                <span class="od-value">@Model.Name</span>
            </div>
            <div class="od-row">
                <span class="od-label">Số điện thoại</span>
                <span class="od-value">@Model.Phone</span>
            </div>
            <div class="od-row">
                <span class="od-label">Địa chỉ</span>
                <span class="od-value" style="max-width:220px">@Model.Address</span>
            </div>
        </div>
    </div>

    <!-- Products -->
    <div class="od-products">
        <div class="od-products-title">🛒 Sản phẩm trong đơn</div>
        <table class="od-table">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th style="text-align:center">SL</th>
                    <th style="text-align:right">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderDetails)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:12px">
                                @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                {
                                    <img src="@item.Product.ImageUrl" class="prod-img" alt="@item.Product.Name" />
                                }
                                else
                                {
                                    <div class="prod-img-empty">📷</div>
                                }
                                <span class="prod-name">@item.Product?.Name</span>
                            </div>
                        </td>
                        <td class="prod-price">@item.Price.ToString("N0") ₫</td>
                        <td style="text-align:center">
                            <span class="prod-qty">@item.Quantity</span>
                        </td>
                        <td style="text-align:right">
                            <span class="prod-total">@((item.Price * item.Quantity).ToString("N0")) ₫</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Summary -->
    <div class="od-summary">
        <div>
            <div class="od-summary-label">Tổng thanh toán</div>
            <div style="font-family:'Inter',sans-serif;font-size:13px;color:#6a6a9a;margin-top:2px">
                @Model.OrderDetails.Count() sản phẩm
            </div>
        </div>
        <div class="od-summary-price">@Model.TotalPrice.ToString("N0") ₫</div>
    </div>

    <!-- Actions -->
    <div class="od-actions">
        <a asp-action="Index" class="btn-back">← Quay lại</a>

        @if (User.IsInRole("Admin"))
        {
            @if (Model.Status == OrderStatus.Pending)
            {
                <button type="button" class="btn-status btn-ship" onclick="updateOrderStatus(@Model.OrderId, 'Shipping')">
                    🚚 Xác nhận giao hàng
                </button>
            }

            @if (Model.Status == OrderStatus.Shipping)
            {
                <button type="button" class="btn-status btn-done" onclick="updateOrderStatus(@Model.OrderId, 'Completed')">
                    ✅ Hoàn thành
                </button>
            }

            @if (Model.Status != OrderStatus.Completed && Model.Status != OrderStatus.Cancelled)
            {
                <form asp-action="CancelOrder" method="post" style="display:inline" id="cancelForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.OrderId" />
                    <button type="button" class="btn-status btn-cancel" onclick="showCancelModal()">
                        ❌ Hủy đơn
                    </button>
                </form>
            }
        }
    </div>
    <!-- Modal xác nhận hủy -->
    <div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
        <div class="modal-box" onclick="event.stopPropagation()">
            <div class="modal-icon">🗑️</div>
            <div class="modal-title">Xác nhận hủy đơn</div>
            <div class="modal-msg">
                Bạn có chắc muốn hủy đơn hàng<br>
                <span class="modal-name">#@Model.OrderCode - @Model.Name</span>?
            </div>
            <div class="modal-note">Hành động này không thể hoàn tác.</div>
            <div class="modal-actions">
                <button class="modal-btn-back" onclick="closeModal()">Quay lại</button>
                <button class="modal-btn-confirm" onclick="submitCancelDetail()">Hủy đơn</button>
            </div>
        </div>
    </div>
        <script>
        function showCancelModal() {
            document.getElementById('modalOverlay').classList.add('show');
        }

        function closeModal() {
            document.getElementById('modalOverlay').classList.remove('show');
        }

        function submitCancelDetail() {
            document.getElementById('cancelForm').submit();
        }

        function updateOrderStatus(orderId, newStatus) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
            fetch('/AdminOrder/UpdateStatusAjax', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ orderId: orderId, status: newStatus })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('success', data.message);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast('error', data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('error', 'Có lỗi xảy ra');
            });
        }

        function showToast(type, message) {
            const existingToast = document.querySelector('.od-toast');
            if (existingToast && existingToast.id !== 'toast') {
                existingToast.remove();
            }
        
            const toast = document.createElement('div');
            toast.className = `od-toast ${type}`;
            const icon = type === 'success' ? '✅' : '❌';
            toast.innerHTML = `${icon} ${message}`;
        
            const wrap = document.querySelector('.od-wrap');
            const header = document.querySelector('.od-header');
            wrap.insertBefore(toast, header);
        
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.4s';
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeModal();
        });

        const toast = document.getElementById('toast');
        if (toast) {
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.4s';
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        }
    </script>
</div>