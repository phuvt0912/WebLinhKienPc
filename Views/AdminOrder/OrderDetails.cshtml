@model WebLinhKienPc.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Đơn hàng #@Model.OrderId</h3>

        @{
            string statusClass = Model.Status switch
            {
                OrderStatus.Pending => "bg-secondary",
                OrderStatus.Shipping => "bg-warning text-dark",
                OrderStatus.Completed => "bg-success",
                OrderStatus.Cancelled => "bg-danger",
                _ => "bg-secondary"
            };
        }

        <span class="badge @statusClass px-3 py-2">
            @Model.Status
        </span>
    </div>

    <!-- INFO GRID -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card p-3 shadow-sm">
                <h5>Thông tin đơn hàng</h5>
                <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Tổng tiền:</strong> @Model.TotalPrice.ToString("N0") ₫</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-3 shadow-sm">
                <h5>Khách hàng</h5>
                <p><strong>Tên:</strong> @Model.Name</p>
                <p><strong>SĐT:</strong> @Model.Phone</p>
                <p><strong>Địa chỉ:</strong> @Model.Address</p>
            </div>
        </div>
    </div>

    <!-- PRODUCT TABLE -->
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <h5 class="mb-0">Sản phẩm</h5>
        </div>

        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th>SL</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.OrderDetails)
                    {
                        <tr>
                            <td>
                                <strong>@item.Product.Name</strong>
                            </td>

                            <td>
                                @item.Price.ToString("N0") ₫
                            </td>

                            <td>
                                @item.Quantity
                            </td>

                            <td class="text-success fw-bold">
                                @(item.Price* item.Quantity).ToString("N0") ₫
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- TOTAL -->
    <div class="card shadow-sm p-3 text-end">
        <h4 class="text-success">
            Tổng thanh toán: @Model.TotalPrice.ToString("N0") ₫
        </h4>
    </div>

    <!-- ACTION -->
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
    </div>

</div>